#!/usr/bin/env bash
. ./scripts/devcontainer/_assert-in-container "$0" "$@"

# Report on the size of a Darklang sqlite DB. Useful for diagnosing
# "wait why is data.db 9 GB?" situations.
#
# Usage:
#   scripts/dev/db-size-report                       # rundir/data.db
#   scripts/dev/db-size-report path/to/some.db
#   scripts/dev/db-size-report --warn-over-gb 1      # exit 1 if > 1 GiB
#
# What it prints:
#   - File size + page stats
#   - Per-table row counts + estimated bytes (via dbstat virtual table
#     if compiled in; falls back to row-count only otherwise).
#   - Top 5 tables by row count
#   - Top 5 tables by bytes (when dbstat available)
#
# It does not modify the DB.

set -euo pipefail

DB="${1:-rundir/data.db}"
WARN_OVER_GB=""

# Strip any flags from positional handling
args=()
for a in "$@"; do
  case "$a" in
    --warn-over-gb) shift; WARN_OVER_GB="${1:-}"; shift || true ;;
    --warn-over-gb=*) WARN_OVER_GB="${a#*=}" ;;
    *) args+=("$a") ;;
  esac
done
DB="${args[0]:-rundir/data.db}"

if [ ! -f "$DB" ]; then
  echo "DB not found: $DB" >&2
  exit 2
fi

cd "$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

bytes=$(stat -c%s "$DB" 2>/dev/null || stat -f%z "$DB")
human=$(numfmt --to=iec-i --suffix=B "$bytes" 2>/dev/null || echo "$bytes bytes")

echo "# DB size report — $DB"
echo
echo "**File size**: $human ($bytes bytes)"
echo

# Page stats
page_size=$(sqlite3 "$DB" "PRAGMA page_size;" 2>/dev/null || echo "?")
page_count=$(sqlite3 "$DB" "PRAGMA page_count;" 2>/dev/null || echo "?")
freelist=$(sqlite3 "$DB" "PRAGMA freelist_count;" 2>/dev/null || echo "?")
echo "**Pages**: $page_count × $page_size B; freelist $freelist"
echo

# Per-table row counts. Quoted-identifier safe.
tables=$(sqlite3 "$DB" "SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%' ORDER BY name;")

echo "## Per-table row counts"
echo
printf '%-35s  %s\n' "table" "rows"
printf '%-35s  %s\n' "-----" "----"
for t in $tables; do
  count=$(sqlite3 "$DB" "SELECT count(*) FROM \"$t\";" 2>/dev/null || echo "?")
  printf '%-35s  %s\n' "$t" "$count"
done
echo

# Per-table bytes via dbstat (compiled-in on most distros, including
# the one shipped with .NET's Microsoft.Data.Sqlite).
if sqlite3 "$DB" "SELECT 1 FROM dbstat LIMIT 1;" >/dev/null 2>&1; then
  echo "## Top 10 tables by bytes (via dbstat)"
  echo
  printf '%-35s  %15s  %s\n' "table" "bytes" "human"
  printf '%-35s  %15s  %s\n' "-----" "-----" "-----"
  sqlite3 "$DB" \
    "SELECT name, sum(pgsize) AS bytes FROM dbstat GROUP BY name ORDER BY bytes DESC LIMIT 10;" \
    | while IFS='|' read -r name bytes; do
        h=$(numfmt --to=iec-i --suffix=B "$bytes" 2>/dev/null || echo "$bytes B")
        printf '%-35s  %15s  %s\n' "$name" "$bytes" "$h"
      done
  echo
else
  echo "_dbstat virtual table not available — row counts only._"
  echo
fi

# Optional warn
if [ -n "$WARN_OVER_GB" ]; then
  threshold=$((WARN_OVER_GB * 1024 * 1024 * 1024))
  if [ "$bytes" -gt "$threshold" ]; then
    echo "WARN: DB exceeds ${WARN_OVER_GB} GiB threshold." >&2
    exit 1
  fi
fi
