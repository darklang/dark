#!/usr/bin/env bash
. ./scripts/devcontainer/_assert-in-container "$0" "$@"

set -euo pipefail

# collect args
PUBLISHED=false
for i in "$@"
do
  case "${i}" in
    --published)
    PUBLISHED=true
    shift
    ;;
  esac
  case "${i}" in
    --restart=no)
    # Accepted for compatibility with build pipeline; no-op since
    # there is no long-running backend server process anymore.
    shift
    ;;
  esac
done


# misc config and helpers
grey="\033[1;30m"
reset="\033[0m"

function announce() {
  msg="$1"
  filename="$2"
  filename=$(realpath "$filename" --relative-to .)
  echo -e "$msg ($grey$filename$reset)"
}

LOGS="${DARK_CONFIG_RUNDIR}/logs"
MIGRATIONS_LOG="$LOGS/migrations.log"

function exe_path() {
  local service="$1"
  if [[ "$PUBLISHED" == "true" ]]; then
    echo "backend/Build/out/${service}/Release/net10.0/linux-x64/publish/${service}"
  else
    echo "backend/Build/out/${service}/Debug/net10.0/${service}"
  fi
}

LOCALEXEC_EXE=$(exe_path "LocalExec")


# (actual logic starts here)

# Wait for any builds that haven't been yet compiled.
echo "Waiting for builds to be ready"
for ((i=1;i<=1000;i++));
do
  if [[ ! -f "${LOCALEXEC_EXE}" ]]; then
    sleep 0.01
  fi
done
echo "Done waiting for builds to be ready"


# In seed mode: if data.db is missing or empty, copy from seed.db
if [[ "${DARK_CONFIG_PACKAGES_SOURCE:-disk}" == "seed" ]]; then
  DB_PATH="${DARK_CONFIG_RUNDIR}/${DARK_CONFIG_DB_NAME:-data.db}"
  SEED_PATH="${DARK_CONFIG_RUNDIR}/seed.db"
  if [[ ! -f "$DB_PATH" ]] || [[ $(stat -c%s "$DB_PATH" 2>/dev/null || echo 0) -lt 1000000 ]]; then
    if [[ -f "$SEED_PATH" ]]; then
      echo "Copying seed.db as data.db"
      cp "$SEED_PATH" "$DB_PATH"
    fi
  fi
fi

announce "Running migrations" "${MIGRATIONS_LOG}"
"${LOCALEXEC_EXE}" migrations run > "${MIGRATIONS_LOG}" 2>&1

echo "Finished build prep"
