#!/usr/bin/env bash
. ./scripts/devcontainer/_assert-in-container "$0" "$@"

set -euo pipefail

# This script used to run migrations and start BwdServer. BwdServer is
# gone (replaced by the in-Dark `darklang serve <fn>` flow). The migrations
# half is still useful for the dev-loop watcher in scripts/build/compile,
# which calls this whenever a migration file changes.
#
# `--restart=no` is accepted for compatibility with run-backend-tests's
# legacy two-call shape but is now a no-op (nothing to restart).

PUBLISHED=false
for i in "$@"; do
  case "${i}" in
    --published) PUBLISHED=true; shift ;;
    --restart=no) shift ;;
  esac
done

grey="\033[1;30m"
reset="\033[0m"

LOGS="${DARK_CONFIG_RUNDIR}/logs"
MIGRATIONS_LOG="$LOGS/migrations.log"

if [[ "$PUBLISHED" == "true" ]]; then
  LOCALEXEC_EXE="backend/Build/out/LocalExec/Release/net10.0/publish/LocalExec"
else
  LOCALEXEC_EXE="backend/Build/out/LocalExec/Debug/net10.0/LocalExec"
fi

# Wait for any builds that haven't been compiled yet
echo "Waiting for builds to be ready"
for ((i=1;i<=1000;i++)); do
  if [[ -f "${LOCALEXEC_EXE}" ]]; then
    break
  fi
  sleep 0.01
done
echo "Done waiting for builds to be ready"

# In seed mode: if data.db is missing or empty, copy from seed.db
if [[ "${DARK_CONFIG_PACKAGES_SOURCE:-disk}" == "seed" ]]; then
  DB_PATH="${DARK_CONFIG_RUNDIR}/${DARK_CONFIG_DB_NAME:-data.db}"
  SEED_PATH="${DARK_CONFIG_RUNDIR}/seed.db"
  if [[ ! -f "$DB_PATH" ]] || [[ $(stat -c%s "$DB_PATH" 2>/dev/null || echo 0) -lt 1000000 ]]; then
    if [[ -f "$SEED_PATH" ]]; then
      echo "Copying seed.db as data.db"
      cp "$SEED_PATH" "$DB_PATH"
    fi
  fi
fi

echo -e "Running migrations (${grey}${MIGRATIONS_LOG}${reset})"
"${LOCALEXEC_EXE}" migrations run > "${MIGRATIONS_LOG}" 2>&1
