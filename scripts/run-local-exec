#!/usr/bin/env bash
. ./scripts/devcontainer/_assert-in-container "$0" "$@"

set -euo pipefail

PUBLISHED=false

for i in "$@"
do
  case "${i}" in
    --published)
      PUBLISHED=true
      ;;
    *) ARGS+=("${i}");;
  esac
done

if [[ "$PUBLISHED" == "true" ]]; then
  # See run-backend-tests for why this isn't under linux-x64/.
  EXE="backend/Build/out/LocalExec/Release/net10.0/publish/LocalExec"
else
  EXE="backend/Build/out/LocalExec/Debug/net10.0/LocalExec"
fi

"${EXE}" "${ARGS[@]}"
