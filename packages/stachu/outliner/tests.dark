module Stachu.Outliner.Tests

type TestResult =
  | Pass
  | Fail of message: String

type TestFunction = Unit -> TestResult

type TestSummary =
  { totalTests: Int64
    passedTests: Int64
    failedTests: Int64
    failedTestNames: List<String> }


// --- Helpers ---

let makeState (outline: Stachu.Outliner.Outline) : Stachu.Outliner.State =
  let doc =
    Stachu.Outliner.Document
      { id = 1L
        title = "Test Doc"
        outline = outline }
  Stachu.Outliner.State
    { documents = [doc]
      activeDocId = 1L
      cursor = 0L
      mode = Stachu.Outliner.Mode.Navigate
      nextDocId = 2L }

let assertEq (label: String) (actual: String) (expected: String) : TestResult =
  if actual == expected then
    TestResult.Pass
  else
    TestResult.Fail $"{label}: expected '{expected}', got '{actual}'"

let assertInt (label: String) (actual: Int64) (expected: Int64) : TestResult =
  if actual == expected then
    TestResult.Pass
  else
    TestResult.Fail $"{label}: expected {Stdlib.Int64.toString expected}, got {Stdlib.Int64.toString actual}"


// --- Tests ---

let testDefaultStateHasTwoDocs () : TestResult =
  let state = Stachu.Outliner.defaultState ()
  assertInt "doc count" (Stdlib.List.length state.documents) 2L


let testActiveDocReturnsCorrectDoc () : TestResult =
  let state = Stachu.Outliner.defaultState ()
  let doc = Stachu.Outliner.activeDoc state
  assertEq "title" doc.title "My Notes"


let testFlattenVisibleCountsAllNodes () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "A"); (2L, "B"); (3L, "C"); (4L, "D")]
      [(1L, [2L; 3L])]
      [1L; 4L]
      5L
  let flat = Stachu.Outliner.flattenVisible outline
  assertInt "visible count" (Stdlib.List.length flat) 4L


let testFlattenVisibleRespectsCollapse () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "A"); (2L, "B"); (3L, "C"); (4L, "D")]
      [(1L, [2L; 3L])]
      [1L; 4L]
      5L
  let collapsed = Stachu.Outliner.setCollapsed outline 1L true
  let flat = Stachu.Outliner.flattenVisible collapsed
  assertInt "visible count" (Stdlib.List.length flat) 2L


let testInsertAfterAddsNode () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "First")]
      []
      [1L]
      2L
  let state = makeState outline
  let newState = Stachu.Outliner.insertAfter state
  let doc = Stachu.Outliner.activeDoc newState
  let flat = Stachu.Outliner.flattenVisible doc.outline
  assertInt "visible count" (Stdlib.List.length flat) 2L


let testInsertAfterEmptyTree () : TestResult =
  let outline = Stachu.Outliner.emptyOutline ()
  let state = makeState outline
  let newState = Stachu.Outliner.insertAfter state
  let doc = Stachu.Outliner.activeDoc newState
  assertInt "root count" (Stdlib.List.length doc.outline.rootChildren) 1L


let testDeleteEmptyNode () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, ""); (2L, "Keep")]
      []
      [1L; 2L]
      3L
  let state = makeState outline
  let newState = Stachu.Outliner.deleteNode state
  let doc = Stachu.Outliner.activeDoc newState
  assertInt "root count" (Stdlib.List.length doc.outline.rootChildren) 1L


let testDeleteNonEmptyNodeDoesNothing () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Has text")]
      []
      [1L]
      2L
  let state = makeState outline
  let newState = Stachu.Outliner.deleteNode state
  let doc = Stachu.Outliner.activeDoc newState
  assertInt "root count" (Stdlib.List.length doc.outline.rootChildren) 1L


let testToggleCollapse () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Parent"); (2L, "Child")]
      [(1L, [2L])]
      [1L]
      3L
  let state = makeState outline
  let newState = Stachu.Outliner.toggleCollapse state
  let doc = Stachu.Outliner.activeDoc newState
  let s = Stachu.Outliner.getStructure doc.outline 1L
  if s.collapsed then
    TestResult.Pass
  else
    TestResult.Fail "Expected node to be collapsed"


let testToggleCollapseLeafDoesNothing () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Leaf")]
      []
      [1L]
      2L
  let state = makeState outline
  let newState = Stachu.Outliner.toggleCollapse state
  let doc = Stachu.Outliner.activeDoc newState
  let s = Stachu.Outliner.getStructure doc.outline 1L
  if s.collapsed then
    TestResult.Fail "Leaf should not be collapsible"
  else
    TestResult.Pass


let testIndentNode () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "First"); (2L, "Second")]
      []
      [1L; 2L]
      3L
  let state = { (makeState outline) with cursor = 1L }
  let newState = Stachu.Outliner.indentNode state
  let doc = Stachu.Outliner.activeDoc newState
  let rootCount = Stdlib.List.length doc.outline.rootChildren
  if rootCount == 1L then
    let s = Stachu.Outliner.getStructure doc.outline 1L
    assertInt "child count" (Stdlib.List.length s.children) 1L
  else
    TestResult.Fail $"Expected 1 root after indent, got {Stdlib.Int64.toString rootCount}"


let testOutdentNode () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Parent"); (2L, "Child")]
      [(1L, [2L])]
      [1L]
      3L
  let state = { (makeState outline) with cursor = 1L }
  let newState = Stachu.Outliner.outdentNode state
  let doc = Stachu.Outliner.activeDoc newState
  assertInt "root count" (Stdlib.List.length doc.outline.rootChildren) 2L


let testMoveNodeUp () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "First"); (2L, "Second")]
      []
      [1L; 2L]
      3L
  let state = { (makeState outline) with cursor = 1L }
  let newState = Stachu.Outliner.moveNodeUp state
  let doc = Stachu.Outliner.activeDoc newState
  match Stdlib.List.head doc.outline.rootChildren with
  | Some firstId ->
    let text = Stachu.Outliner.getNodeText doc.outline firstId
    assertEq "first node" text "Second"
  | None -> TestResult.Fail "No root nodes"


let testMoveNodeDown () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "First"); (2L, "Second")]
      []
      [1L; 2L]
      3L
  let state = makeState outline
  let newState = Stachu.Outliner.moveNodeDown state
  let doc = Stachu.Outliner.activeDoc newState
  match Stdlib.List.head doc.outline.rootChildren with
  | Some firstId ->
    let text = Stachu.Outliner.getNodeText doc.outline firstId
    assertEq "first node" text "Second"
  | None -> TestResult.Fail "No root nodes"


let testMoveCursorUpDown () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "A"); (2L, "B"); (3L, "C")]
      []
      [1L; 2L; 3L]
      4L
  let state = makeState outline
  let down1 = Stachu.Outliner.moveCursorDown state
  let down2 = Stachu.Outliner.moveCursorDown down1
  let up1 = Stachu.Outliner.moveCursorUp down2
  if down1.cursor == 1L && down2.cursor == 2L && up1.cursor == 1L then
    TestResult.Pass
  else
    TestResult.Fail $"Cursor movement: d1={Stdlib.Int64.toString down1.cursor} d2={Stdlib.Int64.toString down2.cursor} u1={Stdlib.Int64.toString up1.cursor}"


let testMoveCursorBounds () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Only")]
      []
      [1L]
      2L
  let state = makeState outline
  let upFromZero = Stachu.Outliner.moveCursorUp state
  let downFromMax = Stachu.Outliner.moveCursorDown state
  if upFromZero.cursor == 0L && downFromMax.cursor == 0L then
    TestResult.Pass
  else
    TestResult.Fail "Cursor should not move past bounds"


let testEditMode () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Hello")]
      []
      [1L]
      2L
  let state = makeState outline
  let editing = Stachu.Outliner.enterEditMode state
  match editing.mode with
  | Editing (text, cursor) ->
    if text == "Hello" && cursor == 5L then
      let withChar = Stachu.Outliner.editInsertChar editing "!"
      match withChar.mode with
      | Editing (newText, _newCursor) ->
        assertEq "after insert" newText "Hello!"
      | _ -> TestResult.Fail "Expected editing mode after insert"
    else
      TestResult.Fail $"Expected 'Hello' at cursor 5"
  | _ -> TestResult.Fail "Expected editing mode"


let testEditBackspace () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "AB")]
      []
      [1L]
      2L
  let state = makeState outline
  let editing = Stachu.Outliner.enterEditMode state
  let afterBs = Stachu.Outliner.editBackspace editing
  match afterBs.mode with
  | Editing (text, _cursor) ->
    assertEq "after backspace" text "A"
  | _ -> TestResult.Fail "Expected editing mode"


let testFinishEditing () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Old")]
      []
      [1L]
      2L
  let state = makeState outline
  let editing = Stachu.Outliner.enterEditMode state
  let typed =
    editing
    |> Stachu.Outliner.editBackspace
    |> Stachu.Outliner.editBackspace
    |> Stachu.Outliner.editBackspace
  let withNew =
    typed
    |> Stachu.Outliner.editInsertChar "N"
    |> Stachu.Outliner.editInsertChar "e"
    |> Stachu.Outliner.editInsertChar "w"
  let finished = Stachu.Outliner.finishEditing withNew
  let doc = Stachu.Outliner.activeDoc finished
  let text = Stachu.Outliner.getNodeText doc.outline 1L
  assertEq "node text" text "New"


let testCreateDocument () : TestResult =
  let state = Stachu.Outliner.defaultState ()
  let newState = Stachu.Outliner.createDocument state "Third Doc"
  let count = Stdlib.List.length newState.documents
  if count == 3L && newState.activeDocId == state.nextDocId then
    let doc = Stachu.Outliner.activeDoc newState
    assertEq "doc title" doc.title "Third Doc"
  else
    TestResult.Fail $"Expected 3 docs, got {Stdlib.Int64.toString count}"


let testDeleteDocument () : TestResult =
  let state = Stachu.Outliner.defaultState ()
  let withThree = Stachu.Outliner.createDocument state "Third"
  let thirdDocId = withThree.activeDocId
  let afterDelete = Stachu.Outliner.deleteDocument withThree thirdDocId
  assertInt "doc count" (Stdlib.List.length afterDelete.documents) 2L


let testDeleteOnlyDocDoesNothing () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline [(1L, "X")] [] [1L] 2L
  let state = makeState outline
  let afterDelete = Stachu.Outliner.deleteDocument state 1L
  assertInt "doc count" (Stdlib.List.length afterDelete.documents) 1L


let testRenameDocument () : TestResult =
  let state = Stachu.Outliner.defaultState ()
  let doc = Stachu.Outliner.activeDoc state
  let renamed = Stachu.Outliner.renameDocument state doc.id "New Title"
  let renamedDoc = Stachu.Outliner.activeDoc renamed
  assertEq "title" renamedDoc.title "New Title"


let testSwitchDocument () : TestResult =
  let state = Stachu.Outliner.defaultState ()
  let withThree = Stachu.Outliner.createDocument state "Third"
  let switched = Stachu.Outliner.switchToDocument withThree 1L
  if switched.activeDocId == 1L && switched.cursor == 0L then
    TestResult.Pass
  else
    TestResult.Fail "Switch should set activeDocId and reset cursor"


let testDocPickerMode () : TestResult =
  let state = Stachu.Outliner.defaultState ()
  let inPicker = Stachu.Outliner.enterDocPicker state
  match inPicker.mode with
  | DocPicker idx ->
    if idx == 0L then
      let exited = Stachu.Outliner.exitDocPicker inPicker
      match exited.mode with
      | Navigate -> TestResult.Pass
      | _ -> TestResult.Fail "Expected Navigate after exit"
    else
      TestResult.Fail $"Expected index 0, got {Stdlib.Int64.toString idx}"
  | _ -> TestResult.Fail "Expected DocPicker mode"


let testExportMarkdown () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Root"); (2L, "Child")]
      [(1L, [2L])]
      [1L]
      3L
  let doc =
    Stachu.Outliner.Document { id = 1L; title = "Test"; outline = outline }
  let md = Stachu.Outliner.Export.toMarkdown doc
  if Stdlib.String.contains md "# Test" && Stdlib.String.contains md "- Root" && Stdlib.String.contains md "  - Child" then
    TestResult.Pass
  else
    TestResult.Fail $"Unexpected markdown:\n{md}"


let testExportOpml () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Root"); (2L, "Child")]
      [(1L, [2L])]
      [1L]
      3L
  let doc =
    Stachu.Outliner.Document { id = 1L; title = "Test"; outline = outline }
  let opml = Stachu.Outliner.Export.toOpml doc
  if Stdlib.String.contains opml "<opml" && Stdlib.String.contains opml "<title>Test</title>" && Stdlib.String.contains opml "text=\"Root\"" && Stdlib.String.contains opml "text=\"Child\"" then
    TestResult.Pass
  else
    TestResult.Fail $"Unexpected OPML:\n{opml}"


let testImportMarkdown () : TestResult =
  let md = "# My Doc\n- Alpha\n  - Beta\n- Gamma"
  let doc = Stachu.Outliner.Markdown.import md
  if doc.title == "My Doc" then
    let flat = Stachu.Outliner.flattenVisible doc.outline
    assertInt "visible count" (Stdlib.List.length flat) 3L
  else
    TestResult.Fail $"Expected title 'My Doc', got '{doc.title}'"


let testBuildOutline () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "A"); (2L, "B"); (3L, "C")]
      [(1L, [2L; 3L])]
      [1L]
      4L
  let flat = Stachu.Outliner.flattenVisible outline
  if Stdlib.List.length flat == 3L then
    match Stdlib.List.head flat with
    | Some vn ->
      if vn.text == "A" && vn.hasChildren && vn.depth == 0L then
        TestResult.Pass
      else
        TestResult.Fail "First node should be A with children at depth 0"
    | None -> TestResult.Fail "No visible nodes"
  else
    TestResult.Fail $"Expected 3 visible, got {Stdlib.Int64.toString (Stdlib.List.length flat)}"


let testFindParentId () : TestResult =
  let outline =
    Stachu.Outliner.buildOutline
      [(1L, "Parent"); (2L, "Child"); (3L, "Root2")]
      [(1L, [2L])]
      [1L; 3L]
      4L
  let childParent = Stachu.Outliner.findParentId outline 2L
  let rootParent = Stachu.Outliner.findParentId outline 1L
  match childParent with
  | Some pid ->
    if pid == 1L then
      match rootParent with
      | None -> TestResult.Pass
      | Some _ -> TestResult.Fail "Root node should have no parent"
    else
      TestResult.Fail $"Expected parent 1, got {Stdlib.Int64.toString pid}"
  | None -> TestResult.Fail "Child should have a parent"


// --- Test runner ---

let allTests () : List<(String * TestFunction)> =
  [ ("Default state has two docs", fun () -> testDefaultStateHasTwoDocs ())
    ("Active doc returns correct doc", fun () -> testActiveDocReturnsCorrectDoc ())
    ("Build outline", fun () -> testBuildOutline ())
    ("Find parent id", fun () -> testFindParentId ())
    ("Flatten visible counts all nodes", fun () -> testFlattenVisibleCountsAllNodes ())
    ("Flatten visible respects collapse", fun () -> testFlattenVisibleRespectsCollapse ())
    ("Insert after adds node", fun () -> testInsertAfterAddsNode ())
    ("Insert after empty tree", fun () -> testInsertAfterEmptyTree ())
    ("Delete empty node", fun () -> testDeleteEmptyNode ())
    ("Delete non-empty does nothing", fun () -> testDeleteNonEmptyNodeDoesNothing ())
    ("Toggle collapse", fun () -> testToggleCollapse ())
    ("Toggle collapse leaf no-op", fun () -> testToggleCollapseLeafDoesNothing ())
    ("Indent node", fun () -> testIndentNode ())
    ("Outdent node", fun () -> testOutdentNode ())
    ("Move node up", fun () -> testMoveNodeUp ())
    ("Move node down", fun () -> testMoveNodeDown ())
    ("Cursor up/down", fun () -> testMoveCursorUpDown ())
    ("Cursor bounds", fun () -> testMoveCursorBounds ())
    ("Edit mode", fun () -> testEditMode ())
    ("Edit backspace", fun () -> testEditBackspace ())
    ("Finish editing", fun () -> testFinishEditing ())
    ("Create document", fun () -> testCreateDocument ())
    ("Delete document", fun () -> testDeleteDocument ())
    ("Delete only doc no-op", fun () -> testDeleteOnlyDocDoesNothing ())
    ("Rename document", fun () -> testRenameDocument ())
    ("Switch document", fun () -> testSwitchDocument ())
    ("DocPicker mode", fun () -> testDocPickerMode ())
    ("Export markdown", fun () -> testExportMarkdown ())
    ("Export OPML", fun () -> testExportOpml ())
    ("Import markdown", fun () -> testImportMarkdown ()) ]


let runAllTests () : Int64 =
  let tests = allTests ()

  Stdlib.printLine ""
  Stdlib.printLine "Outliner Tests"
  Stdlib.printLine "=============="

  let initialSummary =
    TestSummary
      { totalTests = 0L
        passedTests = 0L
        failedTests = 0L
        failedTestNames = [] }

  let finalSummary =
    tests
    |> Stdlib.List.fold initialSummary (fun summary pair ->
      let (name, testFn) = pair
      let newSummary =
        { summary with totalTests = summary.totalTests + 1L }

      match testFn () with
      | Pass ->
        Stdlib.printLine $"  PASS  {name}"
        { newSummary with passedTests = newSummary.passedTests + 1L }
      | Fail message ->
        Stdlib.printLine $"  FAIL  {name}: {message}"
        { newSummary with
            failedTests = newSummary.failedTests + 1L
            failedTestNames = Stdlib.List.append newSummary.failedTestNames [name] })

  Stdlib.printLine ""
  Stdlib.printLine $"Results: {Stdlib.Int64.toString finalSummary.passedTests}/{Stdlib.Int64.toString finalSummary.totalTests} passed"

  if finalSummary.failedTests == 0L then
    Stdlib.printLine "All tests passed!"
    0L
  else
    Stdlib.printLine "Failed:"
    finalSummary.failedTestNames
    |> Stdlib.List.iter (fun name -> Stdlib.printLine $"  - {name}")
    1L
