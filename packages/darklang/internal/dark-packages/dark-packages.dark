module Darklang.Internal.DarkPackages

// HTTP router for the package-server endpoints that used to live on the
// `dark-packages` canvas (deleted with the rest of the canvas system in the
// HTTP rewrite). Run via:
//
//   darklang serve Darklang.Internal.DarkPackages.router
//
// Routes (all GET unless noted):
//   /ping                              → "pong"
//   POST /ops                          → ingest a JSON list of PackageOp
//   /ops?limit=N                       → recent PackageOps
//   /stats                             → package counts
//   /search?modules=&searchDepth=&entityTypes=[&text=][&exactMatch=]
//   /:location                         → name resolution / module browse
//   /type/find/:name                   → location → hash
//   /type/get/:hash                    → hash → entity
//   /type/get/with-location/:hash      → hash → entity + location
//   /value/find/:name, /value/get/:hash, /value/get/with-location/:hash
//   /function/find/:name, /function/get/:hash, /function/get/with-location/:hash
//
// Within the single-segment routes, literal paths (`/ping`, `/ops`, `/stats`,
// `/search`) must precede `/:location`, which would otherwise swallow them.
// Multi-segment routes (`/type/...`, etc.) can appear anywhere in the list
// since they can never match a single-segment path.
//
// SECURITY: POST /ops mutates the package store with no authentication. The
// old canvas sat behind canvas auth; under `darklang serve` it's reachable
// by anyone who can hit the listener. Wrap in an auth check before exposing
// publicly.


// ────────────────────────── helpers ──────────────────────────

let okText (text: String) : Stdlib.Http.Response =
  Stdlib.Http.responseWithText text 200L

let okJson (json: String) : Stdlib.Http.Response =
  Stdlib.Http.responseWithJson json 200L

let badRequest (msg: String) : Stdlib.Http.Response =
  Stdlib.Http.responseWithText msg 400L

let notFound () : Stdlib.Http.Response =
  Stdlib.Http.responseWithText "not found" 404L

let serverError (msg: String) : Stdlib.Http.Response =
  Stdlib.Http.responseWithText msg 500L


/// Parse a dotted "Owner.Module.Name" (or "Owner.Name") string into a
/// PackageLocation.
let parseNameToLocation
  (name: String)
  : Stdlib.Result.Result<LanguageTools.ProgramTypes.PackageLocation, String> =
  let parts = Stdlib.String.split name "."
  let partsLength = Stdlib.List.length parts

  if partsLength < 2L then
    Stdlib.Result.Result.Error
      "Invalid name format. Expected 'Owner.Module.Name' or 'Owner.Name'"
  else
    match Stdlib.List.head parts with
    | None ->
      Stdlib.Result.Result.Error "Invalid name format: empty owner segment"
    | Some owner ->
      match Stdlib.List.last parts with
      | None ->
        Stdlib.Result.Result.Error "Invalid name format: empty name segment"
      | Some entityName ->
        match Stdlib.List.tail parts with
        | None -> Stdlib.Result.Result.Error "Invalid name format"
        | Some middleParts ->
          let modules = Stdlib.List.take middleParts (partsLength - 2L)
          Stdlib.Result.Result.Ok
            (LanguageTools.ProgramTypes.PackageLocation
              { owner = owner; modules = modules; name = entityName })


let parseSearchDepth
  (s: String)
  : Stdlib.Result.Result<LanguageTools.ProgramTypes.Search.SearchDepth, String> =
  match s with
  | "direct" ->
    Stdlib.Result.Result.Ok
      LanguageTools.ProgramTypes.Search.SearchDepth.OnlyDirectDescendants
  | "all" ->
    Stdlib.Result.Result.Ok
      LanguageTools.ProgramTypes.Search.SearchDepth.AllDescendants
  | _ ->
    Stdlib.Result.Result.Error
      $"Invalid 'searchDepth': {s}. Expected 'direct' or 'all'."


let parseEntityType
  (s: String)
  : Stdlib.Result.Result<LanguageTools.ProgramTypes.Search.EntityType, String> =
  match s with
  | "type" ->
    Stdlib.Result.Result.Ok LanguageTools.ProgramTypes.Search.EntityType.Type
  | "value" ->
    Stdlib.Result.Result.Ok LanguageTools.ProgramTypes.Search.EntityType.Value
  | "function" ->
    Stdlib.Result.Result.Ok LanguageTools.ProgramTypes.Search.EntityType.Fn
  | "module" ->
    Stdlib.Result.Result.Ok LanguageTools.ProgramTypes.Search.EntityType.Module
  | _ ->
    Stdlib.Result.Result.Error
      $"Invalid 'entityTypes' element: {s}. Expected one of: type, value, function, module."


let parseExactMatch (s: String) : Stdlib.Result.Result<Bool, String> =
  match s with
  | "true" -> Stdlib.Result.Result.Ok true
  | "false" -> Stdlib.Result.Result.Ok false
  | _ ->
    Stdlib.Result.Result.Error
      $"Invalid 'exactMatch': {s}. Expected 'true' or 'false'."


/// Branch the package server reads/writes against. Single-tenant install →
/// always main.
let serverBranchId: Uuid = SCM.Branch.mainBranchId


// ────────────────────────── handlers ──────────────────────────

let pingHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  okText "pong"

let pingHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/ping"; method = "GET"; handler = pingHandlerFn }


let opsPostHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  let bodyStr = Stdlib.String.fromBlobWithReplacement req.body

  match Builtin.jsonParse<List<LanguageTools.ProgramTypes.PackageOp>> bodyStr with
  | Ok ops ->
    match SCM.PackageOps.add serverBranchId ops with
    | Ok insertedCount ->
      let countStr = Stdlib.Int64.toString insertedCount
      okText $"Successfully received and applied {countStr} ops"
    | Error errorMsg -> serverError errorMsg
  | Error _err ->
    badRequest "Invalid request body. Expected JSON list of PackageOp."

let opsPostHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/ops"; method = "POST"; handler = opsPostHandlerFn }


let opsGetHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  match Stdlib.Http.Request.queryParam req "limit" with
  | None -> badRequest "Missing required query parameter: 'limit'"
  | Some limitStr ->
    match Stdlib.Int64.parse limitStr with
    | Error _ -> badRequest "Invalid 'limit' parameter. Expected integer."
    | Ok limit ->
      let ops = SCM.PackageOps.getRecent limit
      let json =
        ops
        |> Builtin.jsonSerialize<List<LanguageTools.ProgramTypes.PackageOp>>
      okJson json

let opsGetHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/ops"; method = "GET"; handler = opsGetHandlerFn }


let statsHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  let stats = Builtin.pmGetStats ()
  let body =
    $"Package stats:
- types: {stats.types |> Stdlib.Int64.toString}
- fns: {stats.fns |> Stdlib.Int64.toString}
- values: {stats.values |> Stdlib.Int64.toString}"
  okText body

let statsHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/stats"; method = "GET"; handler = statsHandlerFn }


let searchHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  match Stdlib.Http.Request.queryParam req "modules" with
  | None -> badRequest "Missing required query parameter: 'modules'"
  | Some modulesStr ->
    match Stdlib.Http.Request.queryParam req "searchDepth" with
    | None -> badRequest "Missing required query parameter: 'searchDepth'"
    | Some depthStr ->
      match parseSearchDepth depthStr with
      | Error errorMsg -> badRequest errorMsg
      | Ok searchDepth ->
        match Stdlib.Http.Request.queryParam req "entityTypes" with
        | None -> badRequest "Missing required query parameter: 'entityTypes'"
        | Some entityTypesStr ->
          let parsedTypes =
            (Stdlib.String.split entityTypesStr ",")
            |> Stdlib.List.map parseEntityType
            |> Stdlib.Result.collect

          match parsedTypes with
          | Error errorMsg -> badRequest errorMsg
          | Ok entityTypesRaw ->
            let entityTypes = Stdlib.List.unique entityTypesRaw

            let exactMatchResult =
              match Stdlib.Http.Request.queryParam req "exactMatch" with
              | None -> Stdlib.Result.Result.Ok false
              | Some s -> parseExactMatch s

            match exactMatchResult with
            | Error errorMsg -> badRequest errorMsg
            | Ok exactMatch ->
              let text =
                match Stdlib.Http.Request.queryParam req "text" with
                | Some t -> t
                | None -> ""

              let query =
                LanguageTools.ProgramTypes.Search.SearchQuery
                  { currentModule = Stdlib.String.split modulesStr "."
                    text = text
                    searchDepth = searchDepth
                    entityTypes = entityTypes
                    exactMatch = exactMatch }

              let results = Builtin.pmSearch serverBranchId query
              let json =
                results
                |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.Search.SearchResults>
              okJson json

let searchHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/search"; method = "GET"; handler = searchHandlerFn }


/// `/:location` — interpret the single path segment as a dotted name. For a
/// one-segment owner, returns direct descendants. For longer names, resolves
/// via `findAny` (type/fn/value) and falls back to a module browse on miss.
let locationHandlerRoute = "/:location"

let locationHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  match Stdlib.HttpServer.getPathParam req locationHandlerRoute "location" with
  | None -> badRequest "Missing :location segment"
  | Some location ->
    let parts = Stdlib.String.split location "."
    let partsLength = Stdlib.List.length parts

    if partsLength < 1L then
      badRequest
        "Invalid location format. Expected 'Owner', 'Owner.Module', or 'Owner.Module.Name'"
    else if partsLength == 1L then
      // single segment → list direct descendants under that owner
      match Stdlib.List.head parts with
      | None -> badRequest "Invalid location: empty segment"
      | Some owner ->
        let searchQuery =
          LanguageTools.ProgramTypes.Search.SearchQuery
            { currentModule = [ owner ]
              text = ""
              searchDepth =
                LanguageTools.ProgramTypes.Search.SearchDepth.OnlyDirectDescendants
              entityTypes = []
              exactMatch = false }

        let results = Builtin.pmSearch serverBranchId searchQuery
        let json =
          results
          |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.Search.SearchResults>
        okJson json
    else
      match parseNameToLocation location with
      | Error errorMsg -> badRequest errorMsg
      | Ok packageLocation ->
        // Try as fn/type/value via the shared helper; module-browse on miss.
        match
          LanguageTools.PackageManager.findAny serverBranchId packageLocation
        with
        | Some ((hash, kind)) ->
          match kind with
          | Fn ->
            match Builtin.pmGetFn hash with
            | Some fn ->
              let json =
                fn
                |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.PackageFn.PackageFn>
              okJson json
            | None -> notFound ()
          | Type ->
            match Builtin.pmGetType hash with
            | Some t ->
              let json =
                t
                |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.PackageType.PackageType>
              okJson json
            | None -> notFound ()
          | Value ->
            match Builtin.pmGetValue hash with
            | Some v ->
              let json =
                v
                |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.PackageValue.PackageValue>
              okJson json
            | None -> notFound ()
        | None ->
          // Not a leaf — treat the whole path as a module to browse.
          let searchQuery =
            LanguageTools.ProgramTypes.Search.SearchQuery
              { currentModule = parts
                text = ""
                searchDepth =
                  LanguageTools.ProgramTypes.Search.SearchDepth.OnlyDirectDescendants
                entityTypes = []
                exactMatch = false }
          let results = Builtin.pmSearch serverBranchId searchQuery
          let json =
            results
            |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.Search.SearchResults>
          okJson json

let locationHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = locationHandlerRoute
      method = "GET"
      handler = locationHandlerFn }


// ───── per-kind find / get / get-with-location ─────
//
// `:hash` carries a hex SHA-256 (the `Hash` content). The old canvas exposed
// these as UUID `:id` segments because hashes were UUIDs back then; the
// schema moved to content-addressed hashes, so we accept the hash hex
// directly with no parse step.

let typeFindRoute = "/type/find/:name"
let typeFindHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  match Stdlib.HttpServer.getPathParam req typeFindRoute "name" with
  | None -> badRequest "Missing :name segment"
  | Some name ->
    match parseNameToLocation name with
    | Error errorMsg -> badRequest errorMsg
    | Ok location ->
      match Builtin.pmFindType serverBranchId location with
      | Some hash ->
        okJson (hash |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.Hash>)
      | None -> notFound ()

let typeFindHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = typeFindRoute; method = "GET"; handler = typeFindHandlerFn }


let typeGetRoute = "/type/get/:hash"
let typeGetHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  match Stdlib.HttpServer.getPathParam req typeGetRoute "hash" with
  | None -> badRequest "Missing :hash segment"
  | Some hashStr ->
    let hash = LanguageTools.ProgramTypes.Hash.Hash hashStr
    match Builtin.pmGetType hash with
    | Some t ->
      let json =
        t
        |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.PackageType.PackageType>
      okJson json
    | None -> notFound ()

let typeGetHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = typeGetRoute; method = "GET"; handler = typeGetHandlerFn }


let typeGetWithLocationRoute = "/type/get/with-location/:hash"
let typeGetWithLocationHandlerFn
  (req: Stdlib.Http.Request)
  : Stdlib.Http.Response =
  match Stdlib.HttpServer.getPathParam req typeGetWithLocationRoute "hash" with
  | None -> badRequest "Missing :hash segment"
  | Some hashStr ->
    let hash = LanguageTools.ProgramTypes.Hash.Hash hashStr
    match
      LanguageTools.PackageManager.Type.getWithLocation serverBranchId hash
    with
    | Some locatedItem ->
      let json =
        locatedItem
        |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.LocatedItem<LanguageTools.ProgramTypes.PackageType.PackageType>>
      okJson json
    | None -> notFound ()

let typeGetWithLocationHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = typeGetWithLocationRoute
      method = "GET"
      handler = typeGetWithLocationHandlerFn }


