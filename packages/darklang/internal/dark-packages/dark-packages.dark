    | Some locatedItem ->
      let json =
        locatedItem
        |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.LocatedItem<LanguageTools.ProgramTypes.PackageValue.PackageValue>>
      okJson json
    | None -> notFound ()

let valueGetWithLocationHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = valueGetWithLocationRoute
      method = "GET"
      handler = valueGetWithLocationHandlerFn }


let functionFindRoute = "/function/find/:name"
let functionFindHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  match Stdlib.HttpServer.getPathParam req functionFindRoute "name" with
  | None -> badRequest "Missing :name segment"
  | Some name ->
    match parseNameToLocation name with
    | Error errorMsg -> badRequest errorMsg
    | Ok location ->
      match Builtin.pmFindFn serverBranchId location with
      | Some hash ->
        okJson (hash |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.Hash>)
      | None -> notFound ()

let functionFindHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = functionFindRoute
      method = "GET"
      handler = functionFindHandlerFn }


let functionGetRoute = "/function/get/:hash"
let functionGetHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  match Stdlib.HttpServer.getPathParam req functionGetRoute "hash" with
  | None -> badRequest "Missing :hash segment"
  | Some hashStr ->
    let hash = LanguageTools.ProgramTypes.Hash.Hash hashStr
    match Builtin.pmGetFn hash with
    | Some f ->
      let json =
        f
        |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.PackageFn.PackageFn>
      okJson json
    | None -> notFound ()

let functionGetHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = functionGetRoute; method = "GET"; handler = functionGetHandlerFn }


let functionGetWithLocationRoute = "/function/get/with-location/:hash"
let functionGetWithLocationHandlerFn
  (req: Stdlib.Http.Request)
  : Stdlib.Http.Response =
  match
    Stdlib.HttpServer.getPathParam req functionGetWithLocationRoute "hash"
  with
  | None -> badRequest "Missing :hash segment"
  | Some hashStr ->
    let hash = LanguageTools.ProgramTypes.Hash.Hash hashStr
    match
      LanguageTools.PackageManager.Function.getWithLocation
        serverBranchId
        hash
    with
    | Some locatedItem ->
      let json =
        locatedItem
        |> Builtin.jsonSerialize<LanguageTools.ProgramTypes.LocatedItem<LanguageTools.ProgramTypes.PackageFn.PackageFn>>
      okJson json
    | None -> notFound ()

let functionGetWithLocationHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = functionGetWithLocationRoute
      method = "GET"
      handler = functionGetWithLocationHandlerFn }


// ────────────────────────── router ──────────────────────────
//
// Order matters within the single-segment block: literal routes must
// precede the `/:location` catch-all. Multi-segment routes are listed
// first by convention only — they cannot collide with single-segment
// paths regardless of order.

let handlers: List<Stdlib.HttpServer.Handler> =
  [ // multi-segment: /type/...
    typeFindHandler
    typeGetWithLocationHandler
    typeGetHandler
    // multi-segment: /value/...
    valueFindHandler
    valueGetWithLocationHandler
    valueGetHandler
    // multi-segment: /function/...
    functionFindHandler
    functionGetWithLocationHandler
    functionGetHandler
    // single-segment literals (must precede /:location)
    pingHandler
    opsPostHandler
    opsGetHandler
    statsHandler
    searchHandler
    // catch-all single-segment lookup
    locationHandler ]


let router (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  Stdlib.HttpServer.routeRequest handlers req
