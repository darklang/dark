/// Anthropic Claude API - Content
/// Content blocks, messages, and their builders
module Darklang.WIP.AI.Anthropic.Content

type Json = Stdlib.AltJson.Json


// ---------------------------------------------------------------------------
// ROLE TYPE
// ---------------------------------------------------------------------------

type Role =
  | User
  | Assistant

module Role =
  let toString (role: Role) : String =
    match role with
    | User -> "user"
    | Assistant -> "assistant"

  let parse (s: String) : Stdlib.Option.Option<Role> =
    if s == "user" then Stdlib.Option.Option.Some Role.User
    else if s == "assistant" then Stdlib.Option.Option.Some Role.Assistant
    else Stdlib.Option.Option.None


// ---------------------------------------------------------------------------
// CONTENT TYPE
// ---------------------------------------------------------------------------

/// Content block types that can appear in messages
/// Top-level types appear directly in messages.content array
/// Nested types (inside tool results) are parsed via contentJson field
type ContentType =
  // Core content types
  | Text
  | Image
  | Document
  // Tool interactions
  | ToolUse
  | ToolResult
  | ServerToolUse
  // Extended thinking
  | Thinking
  | RedactedThinking
  // Server tool results (top-level containers)
  | WebSearchToolResult
  | WebFetchToolResult
  | CodeExecutionToolResult
  | ToolSearchToolResult
  // Nested result type (inside WebSearchToolResult)
  | SearchResult
  // Other content types
  | ToolReference
  | ContainerUpload
  // Fallback for unknown types
  | Unknown of String

module ContentType =
  let toString (ct: ContentType) : String =
    match ct with
    | Text -> "text"
    | Image -> "image"
    | Document -> "document"
    | ToolUse -> "tool_use"
    | ToolResult -> "tool_result"
    | ServerToolUse -> "server_tool_use"
    | Thinking -> "thinking"
    | RedactedThinking -> "redacted_thinking"
    | WebSearchToolResult -> "web_search_tool_result"
    | WebFetchToolResult -> "web_fetch_tool_result"
    | CodeExecutionToolResult -> "code_execution_tool_result"
    | ToolSearchToolResult -> "tool_search_tool_result"
    | SearchResult -> "search_result"
    | ToolReference -> "tool_reference"
    | ContainerUpload -> "container_upload"
    | Unknown s -> s

  let parse (s: String) : ContentType =
    match s with
    | "text" -> ContentType.Text
    | "image" -> ContentType.Image
    | "document" -> ContentType.Document
    | "tool_use" -> ContentType.ToolUse
    | "tool_result" -> ContentType.ToolResult
    | "server_tool_use" -> ContentType.ServerToolUse
    | "thinking" -> ContentType.Thinking
    | "redacted_thinking" -> ContentType.RedactedThinking
    | "web_search_tool_result" -> ContentType.WebSearchToolResult
    | "web_fetch_tool_result" -> ContentType.WebFetchToolResult
    | "code_execution_tool_result" -> ContentType.CodeExecutionToolResult
    | "tool_search_tool_result" -> ContentType.ToolSearchToolResult
    | "search_result" -> ContentType.SearchResult
    | "tool_reference" -> ContentType.ToolReference
    | "container_upload" -> ContentType.ContainerUpload
    | _ -> ContentType.Unknown s


// ---------------------------------------------------------------------------
// CALLER TYPES
// Indicates how a tool was invoked (directly by model or by server tool)
// ---------------------------------------------------------------------------

type CallerType =
  | Direct
  | CodeExecution20250825 of String  // tool_id
  | CodeExecution20260120 of String  // tool_id

module CallerType =
  let toJson (caller: CallerType) : Stdlib.AltJson.Json =
    match caller with
    | Direct ->
      Stdlib.AltJson.Json.Object [ ("type", Stdlib.AltJson.Json.String "direct") ]
    | CodeExecution20250825 toolId ->
      Stdlib.AltJson.Json.Object
        [ ("type", Stdlib.AltJson.Json.String "code_execution_20250825")
          ("tool_id", Stdlib.AltJson.Json.String toolId) ]
    | CodeExecution20260120 toolId ->
      Stdlib.AltJson.Json.Object
        [ ("type", Stdlib.AltJson.Json.String "code_execution_20260120")
          ("tool_id", Stdlib.AltJson.Json.String toolId) ]

  let parse (json: Stdlib.AltJson.Json) : Stdlib.Option.Option<CallerType> =
    match json with
    | Object fields ->
      let typeStr = JsonHelpers.getString "type" fields
      match typeStr with
      | Some "direct" -> Stdlib.Option.Option.Some CallerType.Direct
      | Some "code_execution_20250825" ->
        match JsonHelpers.getString "tool_id" fields with
        | Some toolId -> Stdlib.Option.Option.Some(CallerType.CodeExecution20250825 toolId)
        | None -> Stdlib.Option.Option.None
      | Some "code_execution_20260120" ->
        match JsonHelpers.getString "tool_id" fields with
        | Some toolId -> Stdlib.Option.Option.Some(CallerType.CodeExecution20260120 toolId)
        | None -> Stdlib.Option.Option.None
      | _ -> Stdlib.Option.Option.None
    | _ -> Stdlib.Option.Option.None


// ---------------------------------------------------------------------------
// TOOL RESULT ERROR TYPES
// Error codes returned by various server tools
// ---------------------------------------------------------------------------

/// Common error codes shared across multiple tool types
type ToolErrorCode =
  // Common errors
  | InvalidToolInput
  | Unavailable
  | TooManyRequests
  | MaxUsesExceeded
  | ExecutionTimeExceeded
  // Web search specific
  | QueryTooLong
  | RequestTooLarge
  // Web fetch specific
  | UrlTooLong
  | UrlNotAllowed
  | UrlNotAccessible
  | UnsupportedContentType
  // Code execution specific
  | OutputFileTooLarge
  // Text editor specific
  | FileNotFound
  // Unknown error
  | Unknown of String

module ToolErrorCode =
  let toString (code: ToolErrorCode) : String =
    match code with
    | InvalidToolInput -> "invalid_tool_input"
    | Unavailable -> "unavailable"
    | TooManyRequests -> "too_many_requests"
    | MaxUsesExceeded -> "max_uses_exceeded"
    | ExecutionTimeExceeded -> "execution_time_exceeded"
    | QueryTooLong -> "query_too_long"
    | RequestTooLarge -> "request_too_large"
    | UrlTooLong -> "url_too_long"
    | UrlNotAllowed -> "url_not_allowed"
    | UrlNotAccessible -> "url_not_accessible"
    | UnsupportedContentType -> "unsupported_content_type"
    | OutputFileTooLarge -> "output_file_too_large"
    | FileNotFound -> "file_not_found"
    | Unknown s -> s

  let parse (s: String) : ToolErrorCode =
    match s with
    | "invalid_tool_input" -> ToolErrorCode.InvalidToolInput
    | "unavailable" -> ToolErrorCode.Unavailable
    | "too_many_requests" -> ToolErrorCode.TooManyRequests
    | "max_uses_exceeded" -> ToolErrorCode.MaxUsesExceeded
    | "execution_time_exceeded" -> ToolErrorCode.ExecutionTimeExceeded
    | "query_too_long" -> ToolErrorCode.QueryTooLong
    | "request_too_large" -> ToolErrorCode.RequestTooLarge
    | "url_too_long" -> ToolErrorCode.UrlTooLong
    | "url_not_allowed" -> ToolErrorCode.UrlNotAllowed
    | "url_not_accessible" -> ToolErrorCode.UrlNotAccessible
    | "unsupported_content_type" -> ToolErrorCode.UnsupportedContentType
    | "output_file_too_large" -> ToolErrorCode.OutputFileTooLarge
    | "file_not_found" -> ToolErrorCode.FileNotFound
    | _ -> ToolErrorCode.Unknown s


// ---------------------------------------------------------------------------
// CITATION TYPES
// For document and web search citations
// (Defined before ContentBlock so it can be used in citations field)
// ---------------------------------------------------------------------------

type CitationType =
  | CharLocation
  | PageLocation
  | ContentBlockLocation
  | WebSearchResultLocation
  | SearchResultLocation

module CitationType =
  let toString (ct: CitationType) : String =
    match ct with
    | CharLocation -> "char_location"
    | PageLocation -> "page_location"
    | ContentBlockLocation -> "content_block_location"
    | WebSearchResultLocation -> "web_search_result_location"
    | SearchResultLocation -> "search_result_location"

  let parse (s: String) : Stdlib.Option.Option<CitationType> =
    match s with
    | "char_location" -> Stdlib.Option.Option.Some CitationType.CharLocation
    | "page_location" -> Stdlib.Option.Option.Some CitationType.PageLocation
    | "content_block_location" ->
      Stdlib.Option.Option.Some CitationType.ContentBlockLocation
    | "web_search_result_location" ->
      Stdlib.Option.Option.Some CitationType.WebSearchResultLocation
    | "search_result_location" ->
      Stdlib.Option.Option.Some CitationType.SearchResultLocation
    | _ -> Stdlib.Option.Option.None

type Citation =
  { ``type``: CitationType
    cited_text: String
    // For char_location
    document_index: Stdlib.Option.Option<Int64>
    document_title: Stdlib.Option.Option<String>
    start_char_index: Stdlib.Option.Option<Int64>
    end_char_index: Stdlib.Option.Option<Int64>
    // For page_location
    start_page_number: Stdlib.Option.Option<Int64>
    end_page_number: Stdlib.Option.Option<Int64>
    // For content_block_location and search_result_location
    start_block_index: Stdlib.Option.Option<Int64>
    end_block_index: Stdlib.Option.Option<Int64>
    // For web_search_result_location
    encrypted_index: Stdlib.Option.Option<String>
    url: Stdlib.Option.Option<String>
    title: Stdlib.Option.Option<String>
    // For search_result_location
    search_result_index: Stdlib.Option.Option<Int64>
    source: Stdlib.Option.Option<String>
    // For output citations (response from API)
    file_id: Stdlib.Option.Option<String> }


// ---------------------------------------------------------------------------
// CONTENT BLOCKS
// Single unified type handles all content block variants
// ---------------------------------------------------------------------------

type ContentBlock =
  { ``type``: ContentType
    // Text content
    text: Stdlib.Option.Option<String>
    // Tool use
    id: Stdlib.Option.Option<String>
    name: Stdlib.Option.Option<String>
    input: Stdlib.Option.Option<Json>
    // Tool result
    tool_use_id: Stdlib.Option.Option<String>
    content: Stdlib.Option.Option<String>
    contentJson: Stdlib.Option.Option<Json>  // For array content (e.g., web_search_tool_result)
    is_error: Stdlib.Option.Option<Bool>
    // Image/Document source
    source: Stdlib.Option.Option<Json>
    // Document-specific
    title: Stdlib.Option.Option<String>
    context: Stdlib.Option.Option<String>
    // Thinking
    thinking: Stdlib.Option.Option<String>
    signature: Stdlib.Option.Option<String>
    data: Stdlib.Option.Option<String>
    // Caching
    cache_control: Stdlib.Option.Option<Models.CacheControl>
    // Citations config (input) - enables citation generation for documents
    citations_enabled: Stdlib.Option.Option<Bool>
    // Citations data (output) - typed list of Citation from API response
    citations: Stdlib.Option.Option<List<Citation>>
    // Web search result fields
    url: Stdlib.Option.Option<String>
    page_age: Stdlib.Option.Option<String>
    encrypted_content: Stdlib.Option.Option<String>
    // Caller - indicates how tool was invoked (direct or via server tool)
    caller: Stdlib.Option.Option<CallerType>
    // Code execution result fields
    stdout: Stdlib.Option.Option<String>
    stderr: Stdlib.Option.Option<String>
    encrypted_stdout: Stdlib.Option.Option<String>  // For PFC + web_search results
    return_code: Stdlib.Option.Option<Int64>
    // Code execution output / container upload
    file_id: Stdlib.Option.Option<String>
    // Web fetch result fields
    retrieved_at: Stdlib.Option.Option<String>  // ISO 8601 timestamp
    // Text editor result fields
    file_type: Stdlib.Option.Option<String>  // "text" | "image" | "pdf"
    start_line: Stdlib.Option.Option<Int64>
    num_lines: Stdlib.Option.Option<Int64>
    total_lines: Stdlib.Option.Option<Int64>
    is_file_update: Stdlib.Option.Option<Bool>
    old_start: Stdlib.Option.Option<Int64>
    old_lines: Stdlib.Option.Option<Int64>
    new_start: Stdlib.Option.Option<Int64>
    new_lines: Stdlib.Option.Option<Int64>
    lines: Stdlib.Option.Option<List<String>>
    // Tool search result fields
    tool_references: Stdlib.Option.Option<List<Json>>
    // Tool reference fields
    tool_name: Stdlib.Option.Option<String>
    // Error fields for tool results
    error_code: Stdlib.Option.Option<String>
    error_message: Stdlib.Option.Option<String> }

let citationCharLocation
  (citedText: String)
  (docIndex: Int64)
  (docTitle: String)
  (startChar: Int64)
  (endChar: Int64)
  : Citation =
  Citation
    { ``type`` = CitationType.CharLocation
      cited_text = citedText
      document_index = Stdlib.Option.Option.Some docIndex
      document_title = Stdlib.Option.Option.Some docTitle
      start_char_index = Stdlib.Option.Option.Some startChar
      end_char_index = Stdlib.Option.Option.Some endChar
      start_page_number = Stdlib.Option.Option.None
      end_page_number = Stdlib.Option.Option.None
      start_block_index = Stdlib.Option.Option.None
      end_block_index = Stdlib.Option.Option.None
      encrypted_index = Stdlib.Option.Option.None
      url = Stdlib.Option.Option.None
      title = Stdlib.Option.Option.None
      search_result_index = Stdlib.Option.Option.None
      source = Stdlib.Option.Option.None
      file_id = Stdlib.Option.Option.None }

