/// LLM Model Registry
/// Pre-defined models with typed access for autocomplete and compile-time safety.
///
/// Usage:
///   Models.Anthropic.sonnet45  // Claude Sonnet 4.5
///   Models.OpenAI.gpt4o        // GPT-4o
///   Models.Local.llama3        // Local Ollama model
module Darklang.LLM.Models


// MODEL DEFINITION

/// A model configuration with provider information
type Model =
  { /// Model identifier to send to the API (e.g., "claude-sonnet-4-5-20250929")
    id: String

    /// Human-readable name (e.g., "Claude Sonnet 4.5")
    name: String

    /// Provider identifier (e.g., "anthropic", "openai", "ollama")
    providerId: String

    /// Maximum context window in tokens
    contextTokens: Int64

    /// Maximum output tokens
    outputTokens: Int64 }


// ANTHROPIC MODELS
// Current Claude models from https://platform.claude.com/docs/en/about-claude/models

module Anthropic =
  // Claude 4.6 (newest, most capable - February 2026)
  let opus46 : Model =
    Model
      { id = "claude-opus-4-6"
        name = "Claude Opus 4.6"
        providerId = "anthropic"
        contextTokens = 200000L  // 1M with beta header
        outputTokens = 128000L }

  let sonnet46 : Model =
    Model
      { id = "claude-sonnet-4-6"
        name = "Claude Sonnet 4.6"
        providerId = "anthropic"
        contextTokens = 200000L  // 1M with beta header
        outputTokens = 64000L }

  // Claude 4.5 family
  let opus45 : Model =
    Model
      { id = "claude-opus-4-5-20251101"
        name = "Claude Opus 4.5"
        providerId = "anthropic"
        contextTokens = 200000L
        outputTokens = 64000L }

  let sonnet45 : Model =
    Model
      { id = "claude-sonnet-4-5-20250929"
        name = "Claude Sonnet 4.5"
        providerId = "anthropic"
        contextTokens = 200000L
        outputTokens = 64000L }

  let haiku45 : Model =
    Model
      { id = "claude-haiku-4-5-20251001"
        name = "Claude Haiku 4.5"
        providerId = "anthropic"
        contextTokens = 200000L
        outputTokens = 64000L }

  // Claude 4 family
  let sonnet4 : Model =
    Model
      { id = "claude-sonnet-4-20250514"
        name = "Claude Sonnet 4"
        providerId = "anthropic"
        contextTokens = 200000L
        outputTokens = 64000L }

  let opus4 : Model =
    Model
      { id = "claude-opus-4-20250514"
        name = "Claude Opus 4"
        providerId = "anthropic"
        contextTokens = 200000L
        outputTokens = 32000L }

  // Claude 3.7
  let sonnet37 : Model =
    Model
      { id = "claude-3-7-sonnet-20250219"
        name = "Claude Sonnet 3.7"
        providerId = "anthropic"
        contextTokens = 200000L
        outputTokens = 64000L }

  // Claude 3 (legacy)
  let haiku3 : Model =
    Model
      { id = "claude-3-haiku-20240307"
        name = "Claude Haiku 3"
        providerId = "anthropic"
        contextTokens = 200000L
        outputTokens = 4096L }

  /// Balanced: good balance of speed/quality (Sonnet 4.6 - latest)
  let balanced : Model = sonnet46

  /// Fast: optimized for speed and cost
  let fast : Model = haiku45

  /// Smart: most capable for complex reasoning
  let smart : Model = opus46


