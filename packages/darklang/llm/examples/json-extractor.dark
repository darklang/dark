/// JSON Extractor
/// Extract structured data from text using OpenAI's JSON mode
/// Run with: ./scripts/run-cli eval 'Darklang.LLM.Examples.JsonExtractor.extractContact "..."'
module Darklang.LLM.Examples.JsonExtractor

type Json = Stdlib.AltJson.Json


// CONTACT EXTRACTION

let contactPrompt =
  "Extract contact info as JSON: {name, email, phone, company, title, address}. Use null for missing fields."


let contactAgent =
  (Darklang.LLM.Agent.create ())
  |> Darklang.LLM.Agent.withSystemPrompt contactPrompt
  |> Darklang.LLM.Agent.useGPT4oMini
  |> Darklang.LLM.Agent.withJsonMode
  |> Darklang.LLM.Agent.withTemperature 0.0
  |> Darklang.LLM.Agent.withMaxTokens 500L


/// Extract contact information from text
let extractContact (text: String) : String =
  match Darklang.LLM.Agent.run contactAgent $"Extract contact info from:\n\n{text}" with
  | Ok result -> result.response
  | Error e -> $"{{\"error\": \"{e}\"}}"


/// Parsed contact info
type ContactInfo =
  { name: Stdlib.Option.Option<String>
    email: Stdlib.Option.Option<String>
    phone: Stdlib.Option.Option<String>
    company: Stdlib.Option.Option<String>
    title: Stdlib.Option.Option<String>
    address: Stdlib.Option.Option<String> }


let extractContactParsed (text: String) : Stdlib.Result.Result<ContactInfo, String> =
  match Stdlib.AltJson.parse (extractContact text) with
  | Error e -> Stdlib.Result.Result.Error e
  | Ok (Object fields) ->
    Stdlib.Result.Result.Ok(
      ContactInfo
        { name = Darklang.LLM.Internal.JsonHelpers.getString "name" fields
          email = Darklang.LLM.Internal.JsonHelpers.getString "email" fields
          phone = Darklang.LLM.Internal.JsonHelpers.getString "phone" fields
          company = Darklang.LLM.Internal.JsonHelpers.getString "company" fields
          title = Darklang.LLM.Internal.JsonHelpers.getString "title" fields
          address = Darklang.LLM.Internal.JsonHelpers.getString "address" fields })
  | Ok _ -> Stdlib.Result.Result.Error "Expected JSON object"



// EVENT EXTRACTION

let eventPrompt =
  "Extract event info as JSON: {title, date (YYYY-MM-DD), time (HH:MM), location, description, attendees:[]}."


let eventAgent =
  (Darklang.LLM.Agent.create ())
  |> Darklang.LLM.Agent.withSystemPrompt eventPrompt
  |> Darklang.LLM.Agent.useGPT4oMini
  |> Darklang.LLM.Agent.withJsonMode
  |> Darklang.LLM.Agent.withTemperature 0.0
  |> Darklang.LLM.Agent.withMaxTokens 500L


/// Extract event information from text
let extractEvent (text: String) : String =
  match Darklang.LLM.Agent.run eventAgent $"Extract event info from:\n\n{text}" with
  | Ok result -> result.response
  | Error e -> $"{{\"error\": \"{e}\"}}"



// ENTITY EXTRACTION

let entityPrompt =
  "Extract named entities as JSON: {people:[], organizations:[], locations:[], dates:[], amounts:[]}."


let entityAgent =
  (Darklang.LLM.Agent.create ())
  |> Darklang.LLM.Agent.withSystemPrompt entityPrompt
  |> Darklang.LLM.Agent.useGPT4oMini
  |> Darklang.LLM.Agent.withJsonMode
  |> Darklang.LLM.Agent.withTemperature 0.0
  |> Darklang.LLM.Agent.withMaxTokens 1000L


/// Extract named entities from text
let extractEntities (text: String) : String =
  match Darklang.LLM.Agent.run entityAgent $"Extract entities from:\n\n{text}" with
  | Ok result -> result.response
  | Error e -> $"{{\"error\": \"{e}\"}}"



// SENTIMENT ANALYSIS

let sentimentPrompt =
  "Analyze sentiment as JSON: {overall_sentiment, confidence (0-1), emotions:[], key_phrases:[], summary}."


let sentimentAgent =
  (Darklang.LLM.Agent.create ())
  |> Darklang.LLM.Agent.withSystemPrompt sentimentPrompt
  |> Darklang.LLM.Agent.useGPT4oMini
  |> Darklang.LLM.Agent.withJsonMode
  |> Darklang.LLM.Agent.withTemperature 0.0
  |> Darklang.LLM.Agent.withMaxTokens 500L


/// Analyze sentiment of text
let analyzeSentiment (text: String) : String =
  match Darklang.LLM.Agent.run sentimentAgent $"Analyze sentiment:\n\n{text}" with
  | Ok result -> result.response
  | Error e -> $"{{\"error\": \"{e}\"}}"



// GENERIC EXTRACTION

/// Extract data using a custom schema description
let extractWithSchema (schemaDescription: String) (text: String) : String =
  let agent =
    (Darklang.LLM.Agent.create ())
    |> Darklang.LLM.Agent.withSystemPrompt $"Extract data as JSON matching: {schemaDescription}"
    |> Darklang.LLM.Agent.useGPT4o
    |> Darklang.LLM.Agent.withJsonMode
    |> Darklang.LLM.Agent.withTemperature 0.0
    |> Darklang.LLM.Agent.withMaxTokens 2000L

  match Darklang.LLM.Agent.run agent $"Extract from:\n\n{text}" with
  | Ok result -> result.response
  | Error e -> $"{{\"error\": \"{e}\"}}"
