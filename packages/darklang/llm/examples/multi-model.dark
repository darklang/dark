/// Multi-Model Comparison
/// Compare responses from different models side by side
/// Run with: ./scripts/run-cli eval 'Darklang.LLM.Examples.MultiModel.compare "What is 1+1?"'
module Darklang.LLM.Examples.MultiModel


/// Result from a single model
type ModelResponse =
  { model: String
    response: String
    inputTokens: Int64
    outputTokens: Int64 }


/// Ask a single model and get response with stats
let askModel
  (model: Darklang.LLM.Models.Model)
  (prompt: String)
  : Stdlib.Result.Result<ModelResponse, String> =
  let agent =
    (Darklang.LLM.Agent.create ())
    |> Darklang.LLM.Agent.withModel model
    |> Darklang.LLM.Agent.withMaxTokens 500L

  match Darklang.LLM.Agent.run agent prompt with
  | Ok result ->
    Stdlib.Result.Result.Ok(
      ModelResponse
        { model = model.id
          response = result.response
          inputTokens = result.usage.inputTokens
          outputTokens = result.usage.outputTokens })
  | Error e -> Stdlib.Result.Result.Error e


/// Format a model result for display
let formatResult (name: String) (result: Stdlib.Result.Result<ModelResponse, String>) : String =
  match result with
  | Ok r -> $"## {name} ({r.model})\n{r.response}\n\n*Tokens: {Stdlib.Int64.toString r.inputTokens} in / {Stdlib.Int64.toString r.outputTokens} out*"
  | Error e -> $"## {name}\nError: {e}"


/// Compare Haiku vs Sonnet responses
let compare (prompt: String) : String =
  let haiku = formatResult "Haiku" (askModel Darklang.LLM.Models.Anthropic.haiku45 prompt)
  let sonnet = formatResult "Sonnet" (askModel Darklang.LLM.Models.Anthropic.sonnet45 prompt)
  $"{haiku}\n\n---\n\n{sonnet}"


/// Compare all three Anthropic models
let compareAll (prompt: String) : String =
  let haiku = formatResult "Haiku" (askModel Darklang.LLM.Models.Anthropic.haiku45 prompt)
  let sonnet = formatResult "Sonnet" (askModel Darklang.LLM.Models.Anthropic.sonnet45 prompt)
  let opus = formatResult "Opus" (askModel Darklang.LLM.Models.Anthropic.opus46 prompt)
  $"{haiku}\n\n---\n\n{sonnet}\n\n---\n\n{opus}"


/// Ask a specific model by name
let ask (modelName: String) (prompt: String) : String =
  let model =
    match modelName with
    | "haiku" -> Darklang.LLM.Models.Anthropic.haiku45
    | "sonnet" -> Darklang.LLM.Models.Anthropic.sonnet45
    | "opus" -> Darklang.LLM.Models.Anthropic.opus46
    | "gpt4o" -> Darklang.LLM.Models.OpenAI.gpt4o
    | "gpt4o-mini" -> Darklang.LLM.Models.OpenAI.gpt4oMini
    | _ -> Darklang.LLM.Models.Anthropic.sonnet45

  match askModel model prompt with
  | Ok r -> r.response
  | Error e -> $"Error: {e}"


/// Compare across providers (Anthropic vs OpenAI)
let compareProviders (prompt: String) : String =
  let sonnet = formatResult "Anthropic Sonnet" (askModel Darklang.LLM.Models.Anthropic.sonnet45 prompt)
  let gpt4o = formatResult "OpenAI GPT-4o" (askModel Darklang.LLM.Models.OpenAI.gpt4o prompt)
  $"{sonnet}\n\n---\n\n{gpt4o}"


/// Compare fast models across providers
let compareFast (prompt: String) : String =
  let haiku = formatResult "Anthropic Haiku" (askModel Darklang.LLM.Models.Anthropic.haiku45 prompt)
  let mini = formatResult "OpenAI GPT-4o Mini" (askModel Darklang.LLM.Models.OpenAI.gpt4oMini prompt)
  $"{haiku}\n\n---\n\n{mini}"
