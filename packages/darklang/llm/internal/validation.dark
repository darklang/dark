/// Input Validation
/// Validates LLM request parameters to catch errors early.
module Darklang.LLM.Internal.Validation


/// Clamp an Int value between min and max (inclusive)
let clamp (value: Int) (min: Int) (max: Int) : Int =
  if value < min then min
  else if value > max then max
  else value

/// Validate max tokens is within reasonable bounds
let validateMaxTokens (tokens: Int) (maxAllowed: Int) : Int =
  clamp tokens 1I maxAllowed

/// Validate max turns is reasonable
let validateMaxTurns (turns: Int) : Int =
  clamp turns 1I 100I

/// Validate temperature with a custom max (provider-specific)
let validateTemperature (temp: Float) (maxTemp: Float) : Float =
  if Stdlib.Float.lessThan temp 0.0 then 0.0
  else if Stdlib.Float.greaterThan temp maxTemp then maxTemp
  else temp
