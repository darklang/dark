/// Anthropic Claude Provider
/// Adapts the Anthropic Claude API to the generic LLM provider interface.
///
/// This provider builds Anthropic API JSON directly,
/// translating between the generic Provider types and Anthropic-specific types.
module Darklang.LLM.Providers.Anthropic

type Json = Stdlib.AltJson.Json
type Provider = Darklang.LLM.Provider.Provider
type Request = Darklang.LLM.Provider.Request
type Response = Darklang.LLM.Provider.Response
type ProviderError = Darklang.LLM.Provider.ProviderError


// CONFIGURATION

type Config =
  { apiKey: String
    baseUrl: String }

/// Get default configuration from environment
/// Returns Error if ANTHROPIC_API_KEY is not set
let defaultConfig () : Stdlib.Result.Result<Config, String> =
  match Internal.ApiKeys.fromEnv "ANTHROPIC_API_KEY" "Anthropic" with
  | Ok apiKey ->
    Stdlib.Result.Result.Ok(
      Config { apiKey = apiKey; baseUrl = "https://api.anthropic.com/v1/messages" })
  | Error e -> Stdlib.Result.Result.Error e




// REQUEST TRANSFORMATION
// Convert generic Request to Anthropic format

/// Convert a generic ToolParameter to a JSON property definition
let parameterToPropertyJson
  (param: Provider.ToolParameter)
  : (String * Json) =
  let propFields = [ ("type", Json.String param.paramType) ]

  let withDesc =
    Stdlib.List.append propFields [ ("description", Json.String param.description) ]

  let withEnum =
    match param.enumValues with
    | Some values ->
      let enumArray = Stdlib.List.map values (fun v -> Json.String v)
      Stdlib.List.append withDesc [ ("enum", Json.Array enumArray) ]
    | None -> withDesc

  (param.name, Json.Object withEnum)

/// Convert a generic ToolSchema to Anthropic tool JSON
let toolSchemaToJson (tool: Provider.ToolSchema) : Json =
  let propsJson =
    Stdlib.List.map tool.parameters parameterToPropertyJson

  let required =
    tool.parameters
    |> Stdlib.List.filter (fun p -> p.required)
    |> Stdlib.List.map (fun p -> Json.String p.name)

  let inputSchemaJson =
    Json.Object
      [ ("type", Json.String "object")
        ("properties", Json.Object propsJson)
        ("required", Json.Array required) ]

  Json.Object
    [ ("name", Json.String tool.name)
      ("description", Json.String tool.description)
      ("input_schema", inputSchemaJson) ]


/// Convert an image source to Anthropic JSON format
let imageSourceToJson (source: Provider.ImageSource) : Json =
  match source with
  | Base64(mediaType, data) ->
    Json.Object
      [ ("type", Json.String "base64")
        ("media_type", Json.String mediaType)
        ("data", Json.String data) ]
  | Url url ->
    Json.Object
      [ ("type", Json.String "url")
        ("url", Json.String url) ]

/// Convert a content block to Anthropic JSON format
let contentBlockToJson (block: Provider.ContentBlock) : Json =
  match block with
  | Text t ->
    Json.Object
      [ ("type", Json.String "text")
        ("text", Json.String t) ]
  | Image source ->
    Json.Object
      [ ("type", Json.String "image")
        ("source", imageSourceToJson source) ]
  | ToolResult(toolUseId, content, isError) ->
    let fields =
      [ ("type", Json.String "tool_result")
        ("tool_use_id", Json.String toolUseId)
        ("content", Json.String content) ]

    let withError =
      if isError then
        Stdlib.List.append fields [ ("is_error", Json.Bool true) ]
      else
        fields

    Json.Object withError
  | ToolUse(id, name, arguments) ->
    Json.Object
      [ ("type", Json.String "tool_use")
        ("id", Json.String id)
        ("name", Json.String name)
        ("input", arguments) ]

/// Convert a message to Anthropic JSON format (handles images and tool results)
let messageToJson (msg: Provider.Message) : Json =
  let role =
    match msg.role with
    | User -> "user"
    | Assistant -> "assistant"
    | System -> "user" // System handled separately

  let isSimpleText =
    match msg.contentBlocks with
    | [ Text _ ] -> true
    | [] -> true
    | _ -> false

  if isSimpleText then
    Json.Object
      [ ("role", Json.String role)
        ("content", Json.String msg.content) ]
  else
    let contentArray = Stdlib.List.map msg.contentBlocks contentBlockToJson

    Json.Object
      [ ("role", Json.String role)
        ("content", Json.Array contentArray) ]



// RESPONSE TRANSFORMATION
// Convert Anthropic response to generic Response

/// Parse Anthropic stop_reason to generic StopReason
let parseStopReason (reason: String) : Provider.StopReason =
  match reason with
  | "end_turn" -> Provider.StopReason.EndTurn
  | "tool_use" -> Provider.StopReason.ToolUse
  | "max_tokens" -> Provider.StopReason.MaxTokens
  | "stop_sequence" -> Provider.StopReason.StopSequence
  | other -> Provider.StopReason.Error other


/// Extract text content from Anthropic response
let extractTextContent (contentArray: List<Json>) : String =
  contentArray
  |> Stdlib.List.filterMap (fun block ->
    match block with
    | Object fields ->
      let blockType = Stdlib.AltJson.Helpers.getString "type" fields
      match blockType with
      | Some "text" -> Stdlib.AltJson.Helpers.getString "text" fields
      | _ -> Stdlib.Option.Option.None
    | _ -> Stdlib.Option.Option.None)
  |> Stdlib.String.join ""


/// Extract tool calls from Anthropic response
let extractToolCalls (contentArray: List<Json>) : List<Provider.ToolCall> =
  contentArray
  |> Stdlib.List.filterMap (fun block ->
    match block with
    | Object fields ->
      let blockType = Stdlib.AltJson.Helpers.getString "type" fields
      match blockType with
      | Some "tool_use" ->
        let id = Stdlib.AltJson.Helpers.getString "id" fields
        let name = Stdlib.AltJson.Helpers.getString "name" fields
        let input = Stdlib.AltJson.Helpers.getValue "input" fields

        match (id, name, input) with
        | (Some i, Some n, Some inp) ->
          Stdlib.Option.Option.Some(
            Provider.ToolCall { id = i; name = n; arguments = inp })
        | _ -> Stdlib.Option.Option.None
      | _ -> Stdlib.Option.Option.None
    | _ -> Stdlib.Option.Option.None)


/// Extract usage from Anthropic response (includes cache tokens)
let extractUsage (fields: List<(String * Json)>) : Provider.Usage =
  let usageFields = Stdlib.AltJson.Helpers.getObject "usage" fields
  let inputTokens = Stdlib.AltJson.Helpers.getInt "input_tokens" usageFields
  let outputTokens = Stdlib.AltJson.Helpers.getInt "output_tokens" usageFields
  let cacheCreationTokens = Stdlib.AltJson.Helpers.getInt "cache_creation_input_tokens" usageFields
  let cacheReadTokens = Stdlib.AltJson.Helpers.getInt "cache_read_input_tokens" usageFields

  Provider.Usage
    { inputTokens = inputTokens
      outputTokens = outputTokens
      cacheCreationTokens = cacheCreationTokens
      cacheReadTokens = cacheReadTokens }




// TOOL RESULT FORMATTING

/// Format tool results for Anthropic's expected format
/// Anthropic expects all tool results in a single user message with content array
let formatToolResults
  (results: List<Provider.ToolResult>)
  : List<Provider.Message> =
  // Anthropic expects tool results as content blocks within a single user message
  let contentBlocks =
    Stdlib.List.map results (fun r ->
      Provider.ContentBlock.ToolResult(r.toolCallId, r.content, r.isError))

  // Create a combined text content for backwards compatibility
  let textContent =
    results
    |> Stdlib.List.map (fun r -> r.content)
    |> Stdlib.String.join "\n"

  // Return as single message with rich content blocks
  [ Provider.Message
      { role = Provider.Role.User
        content = textContent
        contentBlocks = contentBlocks } ]



// EXTENDED REQUEST BUILDING
// For Anthropic-specific features: thinking, web search, web fetch, tool choice

/// Convert generic ToolChoice to Anthropic tool_choice JSON
let toolChoiceToJson
  (choice: Provider.ToolChoice)
  (disableParallel: Bool)
  : Json =
  let baseFields =
    match choice with
    | Auto -> [ ("type", Json.String "auto") ]
    | Any -> [ ("type", Json.String "any") ]
    | Specific name ->
      [ ("type", Json.String "tool")
        ("name", Json.String name) ]
    | None -> [ ("type", Json.String "none") ]

  let withDisableParallel =
    if disableParallel then
      Stdlib.List.append baseFields [ ("disable_parallel_tool_use", Json.Bool true) ]
    else
      baseFields

  Json.Object withDisableParallel


/// Convert ThinkingConfig to Anthropic thinking JSON
let thinkingConfigToJson (config: Provider.ThinkingConfig) : Json =
  match config with
  | Disabled ->
    Json.Object [ ("type", Json.String "disabled") ]
  | Enabled budgetTokens ->
    Json.Object
      [ ("type", Json.String "enabled")
        ("budget_tokens", Json.Number(Stdlib.Int64.toFloat budgetTokens)) ]
  | Adaptive ->
    Json.Object [ ("type", Json.String "adaptive") ]


/// Build domain constraint fields (maxUses, allowedDomains, blockedDomains)
/// Shared by web_search and web_fetch config builders
let buildDomainConstraints
  (baseFields: List<(String * Json)>)
  (maxUses: Stdlib.Option.Option<Int64>)
  (allowedDomains: Stdlib.Option.Option<List<String>>)
  (blockedDomains: Stdlib.Option.Option<List<String>>)
  : List<(String * Json)> =
  let withMaxUses =
    match maxUses with
    | Some n -> Stdlib.List.append baseFields [ ("max_uses", Json.Number(Stdlib.Int64.toFloat n)) ]
    | None -> baseFields

  let withAllowed =
    match allowedDomains with
    | Some domains ->
      let domainsJson = Stdlib.List.map domains (fun d -> Json.String d)
      Stdlib.List.append withMaxUses [ ("allowed_domains", Json.Array domainsJson) ]
    | None -> withMaxUses

  match blockedDomains with
  | Some domains ->
    let domainsJson = Stdlib.List.map domains (fun d -> Json.String d)
    Stdlib.List.append withAllowed [ ("blocked_domains", Json.Array domainsJson) ]
  | None -> withAllowed


/// Convert WebSearchConfig to Anthropic web_search tool JSON
let webSearchConfigToJson (config: Provider.WebSearchConfig) : Json =
  let baseFields =
    [ ("type", Json.String "web_search_20250305")
      ("name", Json.String "web_search") ]

  let fields = buildDomainConstraints baseFields config.maxUses config.allowedDomains config.blockedDomains
  Json.Object fields


/// Convert WebFetchConfig to Anthropic web_fetch tool JSON
let webFetchConfigToJson (config: Provider.WebFetchConfig) : Json =
  let baseFields =
    [ ("type", Json.String "web_fetch_20250910")
      ("name", Json.String "web_fetch") ]

  let fields = buildDomainConstraints baseFields config.maxUses config.allowedDomains config.blockedDomains

  let withCitations =
    if config.enableCitations then
      Stdlib.List.append fields [ ("citations", Json.Object [ ("enabled", Json.Bool true) ]) ]
    else
      fields

  Json.Object withCitations


/// Build an extended request with Anthropic-specific features
let buildExtendedRequest
  (config: Config)
  (req: Request)
  (ext: Provider.RequestExtensions)
  : Json =
  let messagesJson = Stdlib.List.map req.messages messageToJson

  // Build client tools
  let clientTools =
    if Stdlib.List.isEmpty req.tools then
      []
    else
      Stdlib.List.map req.tools toolSchemaToJson

  // Build server tools (web search, web fetch)
  let serverTools =
    let webSearchTool =
      match ext.webSearch with
      | Some config -> [ webSearchConfigToJson config ]
      | None -> []

    let webFetchTool =
      match ext.webFetch with
      | Some config -> [ webFetchConfigToJson config ]
      | None -> []

    Stdlib.List.append webSearchTool webFetchTool

  // Combine all tools
  let allTools = Stdlib.List.append clientTools serverTools

  // Build base fields
  let fields =
    Stdlib.AltJson.Builder.empty
    |> Stdlib.AltJson.Builder.addString "model" req.model
    |> Stdlib.AltJson.Builder.addInt "max_tokens" req.maxTokens

  let withMessages =
    Stdlib.List.append fields [ ("messages", Json.Array messagesJson) ]

  // Add system prompt if present
  let withSystem =
    match req.systemPrompt with
    | Some s -> Stdlib.List.append withMessages [ ("system", Json.String s) ]
    | None -> withMessages

  // Add tools if present
  let withTools =
    if Stdlib.List.isEmpty allTools then
      withSystem
    else
      Stdlib.List.append withSystem [ ("tools", Json.Array allTools) ]

  // Add tool choice if present
  let withToolChoice =
    match ext.toolChoice with
    | Some choice ->
      let choiceJson = toolChoiceToJson choice ext.disableParallelToolUse
      Stdlib.List.append withTools [ ("tool_choice", choiceJson) ]
    | None ->
      if ext.disableParallelToolUse then
        let choiceJson = toolChoiceToJson Provider.ToolChoice.Auto true
        Stdlib.List.append withTools [ ("tool_choice", choiceJson) ]
      else
        withTools

  // Add thinking if present
  let withThinking =
    match ext.thinking with
    | Some config ->
      let thinkingJson = thinkingConfigToJson config
      Stdlib.List.append withToolChoice [ ("thinking", thinkingJson) ]
    | None -> withToolChoice

  // Add temperature if present
  let withTemp =
    match req.temperature with
    | Some t -> Stdlib.List.append withThinking [ ("temperature", Json.Number t) ]
    | None -> withThinking

  Json.Object withTemp



// EXTENDED RESPONSE PARSING
// Extract thinking, web search results, and citations

/// Extract thinking content from Anthropic response
let extractThinking (contentArray: List<Json>) : Stdlib.Option.Option<String> =
  let thinkingBlocks =
    contentArray
    |> Stdlib.List.filterMap (fun block ->
      match block with
      | Object fields ->
        let blockType = Stdlib.AltJson.Helpers.getString "type" fields
        match blockType with
        | Some "thinking" -> Stdlib.AltJson.Helpers.getString "thinking" fields
        | _ -> Stdlib.Option.Option.None
      | _ -> Stdlib.Option.Option.None)

  if Stdlib.List.isEmpty thinkingBlocks then
    Stdlib.Option.Option.None
  else
    Stdlib.Option.Option.Some(Stdlib.String.join thinkingBlocks "\n\n")


/// Extract web search results from Anthropic response
let extractWebSearchResults
  (contentArray: List<Json>)
  : List<Provider.WebSearchResult> =
  contentArray
  |> Stdlib.List.filterMap (fun block ->
    match block with
    | Object fields ->
      let blockType = Stdlib.AltJson.Helpers.getString "type" fields
      match blockType with
      | Some "web_search_tool_result" ->
        // Get the content array inside the result
        let resultContent = Stdlib.AltJson.Helpers.getArray "content" fields

        let results =
          resultContent
          |> Stdlib.List.filterMap (fun item ->
            match item with
            | Object itemFields ->
              let itemType = Stdlib.AltJson.Helpers.getString "type" itemFields
              match itemType with
              | Some "web_search_result" ->
                let url =
                  Stdlib.Option.withDefault
                    (Stdlib.AltJson.Helpers.getString "url" itemFields)
                    ""

                let title =
                  Stdlib.Option.withDefault
                    (Stdlib.AltJson.Helpers.getString "title" itemFields)
                    ""

                let pageAge =
                  Stdlib.AltJson.Helpers.getString "page_age" itemFields

                Stdlib.Option.Option.Some(
                  Provider.WebSearchResult
                    { url = url
                      title = title
                      pageAge = pageAge })
              | _ -> Stdlib.Option.Option.None
            | _ -> Stdlib.Option.Option.None)

        if Stdlib.List.isEmpty results then
          Stdlib.Option.Option.None
        else
          Stdlib.Option.Option.Some results
      | _ -> Stdlib.Option.Option.None
    | _ -> Stdlib.Option.Option.None)
  |> Stdlib.List.flatten


/// Extract citations from a text block
let extractCitationsFromBlock (fields: List<(String * Json)>) : List<Provider.Citation> =
  let citationsArray = Stdlib.AltJson.Helpers.getArray "citations" fields

  citationsArray
  |> Stdlib.List.filterMap (fun citation ->
    match citation with
    | Object citFields ->
      let citationType =
        Stdlib.Option.withDefault
          (Stdlib.AltJson.Helpers.getString "type" citFields)
          "unknown"

      Stdlib.Option.Option.Some(
        Provider.Citation
          { citationType = citationType
            url = Stdlib.AltJson.Helpers.getString "url" citFields
            title = Stdlib.AltJson.Helpers.getString "title" citFields
            citedText = Stdlib.AltJson.Helpers.getString "cited_text" citFields
            startIndex =
              let idx = Stdlib.AltJson.Helpers.getInt "start_index" citFields
              if idx == 0L then Stdlib.Option.Option.None
              else Stdlib.Option.Option.Some idx
            endIndex =
              let idx = Stdlib.AltJson.Helpers.getInt "end_index" citFields
              if idx == 0L then Stdlib.Option.Option.None
              else Stdlib.Option.Option.Some idx })
    | _ -> Stdlib.Option.Option.None)


/// Extract all citations from Anthropic response
let extractCitations (contentArray: List<Json>) : List<Provider.Citation> =
  contentArray
  |> Stdlib.List.filterMap (fun block ->
    match block with
    | Object fields ->
      let blockType = Stdlib.AltJson.Helpers.getString "type" fields
      match blockType with
      | Some "text" ->
        let citations = extractCitationsFromBlock fields
        if Stdlib.List.isEmpty citations then
          Stdlib.Option.Option.None
        else
          Stdlib.Option.Option.Some citations
      | _ -> Stdlib.Option.Option.None
    | _ -> Stdlib.Option.Option.None)
  |> Stdlib.List.flatten


/// Parse extended Anthropic response
let parseExtendedResponse
  (json: Json)
  : Stdlib.Result.Result<Provider.ResponseExtended, ProviderError> =
  match json with
  | Object fields ->
    // Get content array
    let contentArray = Stdlib.AltJson.Helpers.getArray "content" fields

    // Extract text
    let content = extractTextContent contentArray

    // Extract tool calls
    let toolCalls = extractToolCalls contentArray

    // Extract stop reason
    let stopReason =
      match Stdlib.AltJson.Helpers.getString "stop_reason" fields with
      | Some r -> parseStopReason r
      | None -> Provider.StopReason.EndTurn

    // Extract usage
    let usage = extractUsage fields

    // Extract thinking
    let thinking = extractThinking contentArray

    // Extract web search results
    let webSearchResults = extractWebSearchResults contentArray

    // Extract citations
    let citations = extractCitations contentArray

    Stdlib.Result.Result.Ok(
      Provider.ResponseExtended
        { content = content
          stopReason = stopReason
          toolCalls = toolCalls
          usage = usage
          raw = json
          thinking = thinking
          webSearchResults = webSearchResults
          citations = citations
          // Anthropic doesn't have system fingerprint
          systemFingerprint = Stdlib.Option.Option.None })

  | _ ->
    Stdlib.Result.Result.Error(
      Provider.ProviderError.InvalidRequestError "Invalid JSON response")



// EXTENDED HTTP REQUEST

/// Get required beta headers for extended features
let getBetaHeaders (ext: Provider.RequestExtensions) : List<String> =
  let webSearch =
    if Stdlib.Option.isSome ext.webSearch then [ "web-search-2025-03-05" ] else []

  let webFetch =
    if Stdlib.Option.isSome ext.webFetch then [ "web-fetch-2025-09-10" ] else []

  let context =
    if ext.extendedContext then [ "context-1m-2025-08-07" ] else []

  Stdlib.List.flatten [ webSearch; webFetch; context ]


/// Send extended request to Anthropic API
let sendExtendedRequest
  (config: Config)
  (req: Request)
  (ext: Provider.RequestExtensions)
  : Stdlib.Result.Result<Provider.ResponseExtended, ProviderError> =
  let requestJson = buildExtendedRequest config req ext
  let body = Stdlib.AltJson.format requestJson

  // Get required beta headers
  let betas = getBetaHeaders ext

  let baseHeaders =
    [ ("x-api-key", config.apiKey)
      ("anthropic-version", "2023-06-01")
      ("content-type", "application/json") ]

  let headers =
    if Stdlib.List.isEmpty betas then
      baseHeaders
    else
      let betaValue = Stdlib.String.join betas ","
      Stdlib.List.append baseHeaders [ ("anthropic-beta", betaValue) ]

  let httpResult =
    Stdlib.HttpClient.post config.baseUrl headers (Stdlib.String.toBlob body)

  match httpResult with
  | Error e ->
    Stdlib.Result.Result.Error(
      Provider.ProviderError.NetworkError(
        Stdlib.HttpClient.toString e))

  | Ok response ->
    let bodyStr = Stdlib.String.fromBlobWithReplacement response.body

    Internal.HttpErrors.handleResponse
      response.statusCode
      bodyStr
      (fun body ->
        match Stdlib.AltJson.parse body with
        | Ok json -> parseExtendedResponse json
        | Error e ->
          Stdlib.Result.Result.Error(
            Provider.ProviderError.InvalidRequestError e))



// PROVIDER FACTORY

/// Internal helper to build a provider from validated config
let buildProvider (config: Config) : Provider =
  Provider.Provider
    { id = "anthropic"
      name = "Anthropic Claude"
      send = (fun req ->
        (sendExtendedRequest config req Provider.emptyExtensions)
        |> Stdlib.Result.map (fun ext ->
          Provider.Response
            { content = ext.content
              stopReason = ext.stopReason
              toolCalls = ext.toolCalls
              usage = ext.usage
              raw = ext.raw }))
      sendExtended = (fun req ext -> sendExtendedRequest config req ext)
      formatToolResults = formatToolResults
      capabilities =
        Provider.Capabilities
          { supportsTools = true
            supportsStreaming = false
            supportsSystemPrompt = true
            supportsImages = true
            maxContextTokens = 200000L } }


/// Create an Anthropic provider with default configuration
/// Returns Error if ANTHROPIC_API_KEY environment variable is not set
let create () : Stdlib.Result.Result<Provider, String> =
  match defaultConfig () with
  | Ok config -> Stdlib.Result.Result.Ok(buildProvider config)
  | Error e -> Stdlib.Result.Result.Error e



/// Create an Anthropic provider with custom API key
/// Returns Error if the API key is empty
let createWithKey (apiKey: String) : Stdlib.Result.Result<Provider, String> =
  match Internal.ApiKeys.validate apiKey with
  | Ok _ ->
    let config = Config { apiKey = apiKey; baseUrl = "https://api.anthropic.com/v1/messages" }
    Stdlib.Result.Result.Ok(buildProvider config)
  | Error e -> Stdlib.Result.Result.Error e


/// Create an Anthropic provider with full configuration
/// Returns Error if the API key in the config is empty
let createWithConfig (config: Config) : Stdlib.Result.Result<Provider, String> =
  match Internal.ApiKeys.validate config.apiKey with
  | Ok _ -> Stdlib.Result.Result.Ok(buildProvider config)
  | Error e -> Stdlib.Result.Result.Error e
