/// TODO: Env access currently exposes the full process environment. The Builtin
/// should be scoped per-instance (e.g. allowlisted keys) before this is safe
/// for multi-tenant or sandboxed use.
module Darklang.Stdlib.Env

/// Get an environment variable by name, returns None if not set
let get (name: String) : Stdlib.Option.Option<String> =
  Builtin.environmentGet name

/// Get all environment variables as a dictionary
let getAll () : Dict<String> =
  Builtin.environmentGetAll ()
