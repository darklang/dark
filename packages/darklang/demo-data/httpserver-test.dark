module Darklang.DemoData.HttpServerTest

// Test handlers and router for the HTTP server

let helloHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  Stdlib.Http.responseWithText "Hello, World!" 200L

let helloHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/hello"
      method = "GET"
      handler = helloHandlerFn }


let echoHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  let bodyText = Stdlib.String.fromBlobWithReplacement req.body
  Stdlib.Http.responseWithText bodyText 200L

let echoHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/echo"
      method = "POST"
      handler = echoHandlerFn }


let rootHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  Stdlib.Http.responseWithText "Welcome to Darklang HTTP Server!" 200L

let rootHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/"
      method = "GET"
      handler = rootHandlerFn }


// CLEANUP
/// All handlers for the test server
let handlers: List<Stdlib.HttpServer.Handler> =
  [ helloHandler; echoHandler; rootHandler ]


/// Router function - routes requests through our handlers
/// This is a named function so it can be passed to the builtin
let router (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  Stdlib.HttpServer.routeRequest handlers req


// Echoes request.url as the response body. Used to verify
// X-Forwarded-Proto canonicalization in smoke tests.
let urlEchoHandler (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  Stdlib.Http.responseWithText req.url 200L


// ---- Favicon-serving multi-handler example ----
//
// Reads the bundled `favicon-32x32.png` from disk and serves it on
// `/favicon.ico`. Falls back to an empty body if the file isn't
// reachable from the cwd (so the fn is still callable in non-test
// contexts). The test fixture (favicon-multi-handler.test) asserts
// the byte-for-byte roundtrip via the `<IMPORT_DATA_FROM_FILE=...>`
// mechanism.
let faviconHandlerFn (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  let bytes =
    match Stdlib.Cli.File.readBytes "testfiles/data/favicon-32x32.png" with
    | Ok b -> b
    | Error _ -> Stdlib.Blob.empty
  Stdlib.Http.faviconResponse bytes


let faviconHandler: Stdlib.HttpServer.Handler =
  Stdlib.HttpServer.Handler
    { route = "/favicon.ico"
      method = "GET"
      handler = faviconHandlerFn }


/// Multi-handler router that includes a favicon entry alongside the
/// regular handlers.
let routerWithFavicon (req: Stdlib.Http.Request) : Stdlib.Http.Response =
  let allHandlers: List<Stdlib.HttpServer.Handler> =
    [ faviconHandler; helloHandler; echoHandler; rootHandler ]
  Stdlib.HttpServer.routeRequest allHandlers req
