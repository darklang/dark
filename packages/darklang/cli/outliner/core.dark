module Darklang.Cli.Outliner


// --- Types ---

type NodeContent =
  { text: String }

type TreeStructure =
  { children: List<Int>
    collapsed: Bool }

type Outline =
  { nodes: Dict<NodeContent>
    structure: Dict<TreeStructure>
    rootChildren: List<Int>
    nextId: Int }

type VisibleNode =
  { id: Int
    text: String
    depth: Int
    hasChildren: Bool
    childCount: Int
    isCollapsed: Bool }

type Document =
  { id: Int
    title: String
    outline: Outline }

type PersistedData =
  { documents: List<Document>
    activeDocId: Int
    nextDocId: Int }


// --- Outline helpers ---

let k (id: Int) : String =
  Stdlib.Int.toString id

let emptyOutline () : Outline =
  Outline
    { nodes = Stdlib.Dict.empty
      structure = Stdlib.Dict.empty
      rootChildren = []
      nextId = 1I }

let getNodeText (outline: Outline) (id: Int) : String =
  match Stdlib.Dict.get outline.nodes (k id) with
  | Some nc -> nc.text
  | None -> ""

let getStructure (outline: Outline) (id: Int) : TreeStructure =
  match Stdlib.Dict.get outline.structure (k id) with
  | Some s -> s
  | None -> TreeStructure { children = []; collapsed = false }

let addNode (outline: Outline) (id: Int) (text: String) : Outline =
  let key = k id
  let nc = NodeContent { text = text }
  let ts = TreeStructure { children = []; collapsed = false }
  { outline with
      nodes = Stdlib.Dict.setOverridingDuplicates outline.nodes key nc
      structure = Stdlib.Dict.setOverridingDuplicates outline.structure key ts }

let setNodeText (outline: Outline) (id: Int) (text: String) : Outline =
  let key = k id
  let nc = NodeContent { text = text }
  { outline with nodes = Stdlib.Dict.setOverridingDuplicates outline.nodes key nc }

let removeNodeData (outline: Outline) (id: Int) : Outline =
  let key = k id
  { outline with
      nodes = Stdlib.Dict.remove outline.nodes key
      structure = Stdlib.Dict.remove outline.structure key }

let setCollapsed (outline: Outline) (id: Int) (collapsed: Bool) : Outline =
  let key = k id
  match Stdlib.Dict.get outline.structure key with
  | Some s ->
    let updated = { s with collapsed = collapsed }
    { outline with structure = Stdlib.Dict.setOverridingDuplicates outline.structure key updated }
  | None -> outline

let getChildren (outline: Outline) (parentId: Stdlib.Option.Option<Int>) : List<Int> =
  match parentId with
  | None -> outline.rootChildren
  | Some pid ->
    let s = getStructure outline pid
    s.children

let setChildren (outline: Outline) (parentId: Stdlib.Option.Option<Int>) (newChildren: List<Int>) : Outline =
  match parentId with
  | None -> { outline with rootChildren = newChildren }
  | Some pid ->
    let key = k pid
    let s = getStructure outline pid
    let updated = { s with children = newChildren }
    { outline with structure = Stdlib.Dict.setOverridingDuplicates outline.structure key updated }

let findParentId (outline: Outline) (targetId: Int) : Stdlib.Option.Option<Int> =
  if Stdlib.List.any outline.rootChildren (fun id -> id == targetId) then
    Stdlib.Option.Option.None
  else
    (Stdlib.Dict.toList outline.structure)
    |> Stdlib.List.findFirst (fun pair ->
      let (_key, s) = pair
      Stdlib.List.any s.children (fun id -> id == targetId))
    |> Stdlib.Option.map (fun pair ->
      let (key, _s) = pair
      match Stdlib.Int.parse key with
      | Ok id -> id
      | Error _ -> 0I)


// --- List helpers ---

let insertIdAfter (ids: List<Int>) (afterId: Int) (newId: Int) : List<Int> =
  ids
  |> Stdlib.List.fold [] (fun acc id ->
    if id == afterId then
      Stdlib.List.append acc [id; newId]
    else
      Stdlib.List.append acc [id])

let swapAt (ids: List<Int>) (i: Int) (j: Int) : List<Int> =
  let iVal =
    (Stdlib.List.getAt ids i) |> Stdlib.Option.withDefault 0I
  let jVal =
    (Stdlib.List.getAt ids j) |> Stdlib.Option.withDefault 0I
  ids
  |> Stdlib.List.indexedMap (fun idx id ->
    if idx == i then jVal
    else if idx == j then iVal
    else id)


// --- Flatten ---

let flattenVisibleHelper (outline: Outline) (ids: List<Int>) (depth: Int) : List<VisibleNode> =
  ids
  |> Stdlib.List.fold [] (fun acc id ->
    let text = getNodeText outline id
    let s = getStructure outline id
    let hasChildren = Stdlib.Bool.not (Stdlib.List.isEmpty s.children)
    let vn =
      VisibleNode
        { id = id
          text = text
          depth = depth
          hasChildren = hasChildren
          childCount = (Stdlib.List.length s.children)
          isCollapsed = s.collapsed }
    let childNodes =
      if s.collapsed then
        []
      else
        flattenVisibleHelper outline s.children (depth + 1I)
    Stdlib.List.append acc (Stdlib.List.append [vn] childNodes))

let flattenVisible (outline: Outline) : List<VisibleNode> =
  flattenVisibleHelper outline outline.rootChildren 0I


// --- Outline builder ---

let buildOutline
  (nodeList: List<(Int * String)>)
  (childMap: List<(Int * List<Int>)>)
  (roots: List<Int>)
  (nextId: Int)
  : Outline =
  let nodeEntries =
    nodeList
    |> Stdlib.List.map (fun pair ->
      let (id, text) = pair
      (k id, NodeContent { text = text }))
  let nodes = Stdlib.Dict.fromListOverwritingDuplicates nodeEntries
  let structEntries =
    nodeList
    |> Stdlib.List.map (fun pair ->
      let (id, _text) = pair
      let children =
        childMap
        |> Stdlib.List.findFirst (fun cm ->
          let (cmId, _cids) = cm
          cmId == id)
        |> Stdlib.Option.map (fun cm ->
          let (_cmId, cids) = cm
          cids)
        |> Stdlib.Option.withDefault []
      (k id, TreeStructure { children = children; collapsed = false }))
  let structure = Stdlib.Dict.fromListOverwritingDuplicates structEntries
  Outline
    { nodes = nodes
      structure = structure
      rootChildren = roots
      nextId = nextId }
