module Darklang =
  module Test =
    module EArgTests =
      let addTwo (earg1: Int) (earg2: Int): Int =
        Stdlib.Int.add earg1 earg2

      let shadowTest (shadowedEarg: Int): Int =
        let shadowedEarg = 42I
        shadowedEarg  // This should be EVariable, not EArg after shadowing

      let argAndLocalVar (mixedEarg: Int): Int =
        let localVarNotEarg = 10I
        Stdlib.Int.add mixedEarg localVarNotEarg  // mixedEarg=EArg(0), localVarNotEarg=EVariable("localVarNotEarg")

      let nestedShadowing (eargOne: Int) (eargTwo: Int): Int =
        let a =
          let eargOne = 100I
          Stdlib.Int.add eargOne eargTwo
        Stdlib.Int.add a eargOne

      let lambdaTest (eargX: Int) : Int =
        let addX = (fun x -> Stdlib.Int.add x 1I)
        let result = eargX + (addX eargX)
        result

      let matchArgName (value: Int) : Int =
        match value with
        | 0I -> 100I
        | value -> value * 2I

      let matchWithNestedShadowing (x: Int) (y: Int) : Int =
        match x with
        | 0I -> y
        | x -> // This 'x' shadows the parameter
          let y = x * 3I  // This 'y' shadows the second parameter
          match y with
          | 6I -> 600I
          | y -> y + 10I  // This 'y' shadows both parameter and let binding

      let matchWithNestedShadowing2 (x: Int) (y: Int) : Int =
        match y with
        | 0I -> y
        | x -> x * 3I  // This 'x' shadows the first parameter


      let tupleMatchWithArgShadowing (data: (Int * String)) : String =
        match data with
        | (0I, result) -> result
        | (1I, data) -> data ++ "_modified"  // 'data' shadows the parameter
        | (data, text) -> (Stdlib.Int.toString data) ++ "_" ++ text  // 'data' shadows parameter




let test1 = (Darklang.Test.EArgTests.addTwo 3I 4I) == 7I
let test2 = (Darklang.Test.EArgTests.shadowTest 999I) == 42I
let test3 = (Darklang.Test.EArgTests.argAndLocalVar 5I) == 15I
let test4 = (Darklang.Test.EArgTests.nestedShadowing 1I 2I) == 103I
let test5 = (Darklang.Test.EArgTests.lambdaTest 10I) == 21I
let test6 = (Darklang.Test.EArgTests.matchArgName 0I) == 100I
let test7 = (Darklang.Test.EArgTests.matchArgName 5I) == 10I
let test8 = (Darklang.Test.EArgTests.matchWithNestedShadowing 0I 42I) == 42I
let test9 = (Darklang.Test.EArgTests.matchWithNestedShadowing 3I 99I) == 19I
let test10 = (Darklang.Test.EArgTests.matchWithNestedShadowing2 5I 0I) == 0I
let test11 = (Darklang.Test.EArgTests.matchWithNestedShadowing2 5I 4I) == 12I
let test12 = (Darklang.Test.EArgTests.tupleMatchWithArgShadowing (0I, "hello")) == "hello"
let test13 = (Darklang.Test.EArgTests.tupleMatchWithArgShadowing (1I, "test")) == "test_modified"
let test14 = (Darklang.Test.EArgTests.tupleMatchWithArgShadowing (42I, "data")) == "42_data"

let testList = [ test1; test2; test3; test4; test6; test7; test8; test9; test10; test11; test12; test13; test14 ]


match Stdlib.List.all testList Stdlib.Fun.identity with
| true -> 0I
| false -> 1I