module Darklang =
  module Test =
    let factorial (n: Int): Int =
      if Stdlib.Int.lessThanOrEqualTo n 1I then
        1I
      else
      Stdlib.Int.multiply n (Test.factorial (Stdlib.Int.subtract n 1I))


    let fibonacci (n: Int): Int =
      if Stdlib.Int.lessThanOrEqualTo n 1I then
        n
      else
        Stdlib.Int.add
          (Test.fibonacci (Stdlib.Int.subtract n 1I))
          (Test.fibonacci (Stdlib.Int.subtract n 2I))


    let sumUpTo (n: Int): Int =
      if Stdlib.Int.lessThanOrEqualTo n 0I then
        0I
      else
        Stdlib.Int.add n (Test.sumUpTo (Stdlib.Int.subtract n 1I))


  module ShadowingTest =
    let incrementWithShadowing (y: Int) (z: Int): Int =
      if Stdlib.Int.lessThanOrEqualTo z 0I then
        y
      else
        let result =
          incrementWithShadowing y (Stdlib.Int.subtract z 1I)

        let incrementWithShadowing =
          (fun x -> Stdlib.Int.add x 2I)

        Stdlib.Int.add result (incrementWithShadowing z)


    let factorialWithShadowing (n: Int): (String * Int) =
      if Stdlib.Int.lessThanOrEqualTo n 1I then
        ("base_case", 1I)
      else
        let factorialWithShadowing = "shadowed"
        let result = Stdlib.Int.multiply n ((Darklang.ShadowingTest.factorialWithShadowing (Stdlib.Int.subtract n 1I)) |> Stdlib.Tuple2.second)
        (factorialWithShadowing , result)


    let matchWithShadowing (x: Int) : Int =
      match x with
      | 0I -> 0I
      | 1I -> matchWithShadowing 0I
      | 2I ->
        let matchWithShadowing = (fun v -> v * 4I)
        matchWithShadowing 2I
      | matchWithShadowing -> matchWithShadowing + 1I


    let tupleMatchWithShadowing (x: (Int * Int)) : Int =
      match x with
      | (0I, _) -> 0I
      | (1I, n) -> tupleMatchWithShadowing ((0I, n))
      | (2I, v) ->
          let tupleMatchWithShadowing = (fun x -> x * 10I)
          tupleMatchWithShadowing v
      | (a, tupleMatchWithShadowing) -> a + tupleMatchWithShadowing


    let letBindingShadowing (x: Int) : List<Int> =
      let letBindingShadowing = (fun v -> v * 3I)
      let letBindingShadowing = [ 10I; letBindingShadowing x ]
      let letBindingShadowing = Stdlib.List.reverse letBindingShadowing
      letBindingShadowing


    let conditionalShadowing (x: Int) : Int =
      if x <= 0I then
        0I
      else if x < 3I then
        let conditionalShadowing = (fun v w -> v * 5I + w)
        conditionalShadowing x 2I
      else if x < 5I then
        let conditionalShadowing = (fun v -> v * 3I)
        conditionalShadowing x
      else
        x + (conditionalShadowing (x - 1I))


    let pipeWithShadowing (x: Int) : Int =
      match x with
      | 0I -> 0I
      | 1I -> 0I |> pipeWithShadowing
      | 2I ->
        let pipeWithShadowing = (fun v -> v * 6I)
        x |> pipeWithShadowing
      | pipeWithShadowing -> x |> Stdlib.Int.add pipeWithShadowing


    val valueShadowing = 120I
    let valueShadowing (x: Int) : Int =
      if x <= 0I then
        10I
      else if x == 1I then
        (valueShadowing 0I) + 1I
      else
        let result = valueShadowing + 1I
        (valueShadowing (x - 1I)) + result


let test1 = (Darklang.Test.factorial 0I) == 1I
let test2 = (Darklang.Test.factorial 1I) == 1I
let test3 = (Darklang.Test.factorial 5I) == 120I
let test4 = (Darklang.Test.factorial 10I) == 3628800I


let test5 = (Darklang.Test.fibonacci 0I) == 0I
let test6 = (Darklang.Test.fibonacci 1I) == 1I
let test7 = (Darklang.Test.fibonacci 5I) == 5I
let test8 = (Darklang.Test.fibonacci 10I) == 55I


let test9 = (Darklang.Test.sumUpTo 0I) == 0I
let test10 = (Darklang.Test.sumUpTo 1I) == 1I
let test11 = (Darklang.Test.sumUpTo 5I) == 15I
let test12 = (Darklang.Test.sumUpTo 10I) == 55I


let test13 = (Darklang.ShadowingTest.incrementWithShadowing 3I 5I) == 28I
let test14 = (Darklang.ShadowingTest.factorialWithShadowing 5I) == ("shadowed", 120I)
let test15 = (Darklang.ShadowingTest.matchWithShadowing 0I) == 0I
let test16 = (Darklang.ShadowingTest.matchWithShadowing 1I) == 0I
let test17 = (Darklang.ShadowingTest.matchWithShadowing 2I) == 8I
let test18 = (Darklang.ShadowingTest.matchWithShadowing 5I) == 6I

let test19 = (Darklang.ShadowingTest.tupleMatchWithShadowing (0I, 10I)) == 0I
let test20 = (Darklang.ShadowingTest.tupleMatchWithShadowing (1I, 20I)) == 0I
let test21 = (Darklang.ShadowingTest.tupleMatchWithShadowing (2I, 3I)) == 30I
let test22 = (Darklang.ShadowingTest.tupleMatchWithShadowing (4I, 5I)) == 9I

let test23 = (Darklang.ShadowingTest.letBindingShadowing 4I) == [12I; 10I]
let test24 = (Darklang.ShadowingTest.letBindingShadowing 5I) == [15I; 10I]

let test25 = (Darklang.ShadowingTest.conditionalShadowing 0I) == 0I
let test26 = (Darklang.ShadowingTest.conditionalShadowing 1I) == 7I
let test27 = (Darklang.ShadowingTest.conditionalShadowing 2I) == 12I
let test28 = (Darklang.ShadowingTest.conditionalShadowing 3I) == 9I
let test29 = (Darklang.ShadowingTest.conditionalShadowing 4I) == 12I
let test30 = (Darklang.ShadowingTest.conditionalShadowing 5I) == 17I
let test31 = (Darklang.ShadowingTest.conditionalShadowing 6I) == 23I

let test32 = (Darklang.ShadowingTest.pipeWithShadowing 0I) == 0I
let test33 = (Darklang.ShadowingTest.pipeWithShadowing 1I) == 0I
let test34 = (Darklang.ShadowingTest.pipeWithShadowing 2I) == 12I
let test35 = (Darklang.ShadowingTest.pipeWithShadowing 5I) == 10I

let test36 = (Darklang.ShadowingTest.valueShadowing 0I) == 10I
let test37 = (Darklang.ShadowingTest.valueShadowing 1I) == 11I
let test38 = (Darklang.ShadowingTest.valueShadowing 5I) == 495I

let testList = [ test1; test2; test3; test4; test5; test6; test7; test8; test9; test10; test11; test12; test13; test14; test15; test16; test17; test18; test19; test20; test21; test22; test23; test24; test25; test26; test27; test28; test29; test30; test31; test32; test33; test34; test35; test36; test37; test38]

match Stdlib.List.all testList Stdlib.Fun.identity with
| true -> 0I
| false -> 1I