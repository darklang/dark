<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <!-- Publishing configuration -->
    <IsPublishable>false</IsPublishable>
    <IsTrimmable>true</IsTrimmable>
  </PropertyGroup>
  <ItemGroup>
    <None Include="paket.references" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../Prelude/Prelude.fsproj" />
    <ProjectReference Include="../LibExecution/LibExecution.fsproj" />
    <ProjectReference Include="../LibSerialization/LibSerialization.fsproj" />
    <ProjectReference Include="../LibConfig/LibConfig.fsproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Sqlite.fs" />
    <Compile Include="PackageLocation.fs" />
    <Compile Include="Caching.fs" />
    <Compile Include="Purge.fs" />
    <Compile Include="PackageItem.fs" />
    <Compile Include="DependencyExtractor.fs" />
    <Compile Include="BranchOpPlayback.fs" />
    <Compile Include="Branches.fs" />
    <Compile Include="AstTransformer.fs" />
    <Compile Include="HashStabilization.fs" />
    <Compile Include="NameLookup.fs" />
    <Compile Include="DeferredResolver.fs" />
    <Compile Include="PackageOpPlayback.fs" />
    <Compile Include="Inserts.fs" />
    <Compile Include="Queries.fs" />
    <!-- Conflicts compiles before Merge so a branch merge can record its collisions in the same
         reviewable store sync uses (the conflict store is dependency-free — only Sqlite). /-->
    <Compile Include="Conflicts.fs" />
    <Compile Include="Rebase.fs" />
    <Compile Include="Merge.fs" />
    <Compile Include="Stats.fs" />
    <Compile Include="ProgramTypes.fs" />
    <Compile Include="WipRefresh.fs" />
    <Compile Include="Propagation.fs" />
    <Compile Include="RuntimeTypes.fs" />
    <Compile Include="PackageManager.fs" />
    <Compile Include="Scripts.fs" />
    <Compile Include="PackageRefsGenerator.fs" />
    <Compile Include="Seed.fs" />
    <Compile Include="CapabilityGrants.fs" />
    <Compile Include="PackageCaps.fs" />

    <!-- Sync (read/write op-log between instances) /-->
    <Compile Include="Remotes.fs" />
    <Compile Include="SyncCursors.fs" />
    <Compile Include="Sync.fs" />

    <!-- The Release migrator: move a store forward one Release at a time; refuse a newer store. /-->
    <Compile Include="Releases.fs" />

    <!-- ex-LibCloud SQLite-bound modules /-->
    <Compile Include="Tracing.fs" />
    <Compile Include="UserDB.fs" />
  </ItemGroup>
  <Import Project="..\..\.paket\Paket.Restore.targets" />
</Project>