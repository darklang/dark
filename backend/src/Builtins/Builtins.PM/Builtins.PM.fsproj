<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <!-- Publishing configuration -->
    <IsPublishable>false</IsPublishable>
    <IsTrimmable>true</IsTrimmable>
  </PropertyGroup>
  <ItemGroup>
    <None Include="paket.references" />
    <Compile Include="Libs/PackageOps.fs" />
    <Compile Include="Libs/Branches.fs" />
    <Compile Include="Libs/Rebase.fs" />
    <Compile Include="Libs/Merge.fs" />
    <Compile Include="Libs/Packages.fs" />
    <Compile Include="Libs/Scripts.fs" />
    <Compile Include="Libs/Dependencies.fs" />
    <Compile Include="Libs/Seed.fs" />
    <Compile Include="Builtin.fs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../Prelude/Prelude.fsproj" />
    <ProjectReference Include="../../LibExecution/LibExecution.fsproj" />
    <ProjectReference Include="../../LibDB/LibDB.fsproj" />
    <ProjectReference Include="../../LibSerialization/LibSerialization.fsproj" />
  </ItemGroup>
  <Import Project="..\..\..\.paket\Paket.Restore.targets" />
</Project>
