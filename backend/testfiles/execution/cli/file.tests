module WriteReadRoundtrip =
  let testContents () : String = "Test conrents"

  (let filename = (Stdlib.Cli.File.createTemp ()) |> Builtin.unwrap
   let blob = Stdlib.Blob.fromString (testContents ())
   do (Stdlib.Cli.FileSystem.writeFile filename blob) |> Builtin.unwrap

   let readBack =
     Stdlib.Cli.FileSystem.readFile filename |> Builtin.unwrap
   Stdlib.Blob.toString readBack) = Stdlib.Result.Result.Ok(testContents ())
