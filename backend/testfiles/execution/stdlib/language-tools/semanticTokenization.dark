      (TokenType.Number, (0I, 29I), (0I, 30I))
      (TokenType.Symbol, (0I, 30I), (0I, 31I)) ]


module TokenizeExpression =
  ("()" |> tokenize) = [ (TokenType.Symbol, (0I, 0I), (0I, 2I)) ]
  ("true" |> tokenize) = [ (TokenType.Keyword, (0I, 0I), (0I, 4I)) ]

  ("1y" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                         (TokenType.Symbol, (0I, 1I), (0I, 2I)) ]

  ("1uy" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                          (TokenType.Symbol, (0I, 1I), (0I, 3I)) ]

  ("1s" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                         (TokenType.Symbol, (0I, 1I), (0I, 2I)) ]

  ("1us" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                          (TokenType.Symbol, (0I, 1I), (0I, 3I)) ]

  ("1l" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                         (TokenType.Symbol, (0I, 1I), (0I, 2I)) ]

  ("1ul" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                          (TokenType.Symbol, (0I, 1I), (0I, 3I)) ]

  ("1L" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                         (TokenType.Symbol, (0I, 1I), (0I, 2I)) ]

  ("1UL" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                          (TokenType.Symbol, (0I, 1I), (0I, 3I)) ]

  ("1Q" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                         (TokenType.Symbol, (0I, 1I), (0I, 2I)) ]

  ("1Z" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I))
                         (TokenType.Symbol, (0I, 1I), (0I, 2I)) ]

  // suffixless Int literal: just a Number token, no suffix Symbol
  ("1" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 1I)) ]

  ("12345678901234567890" |> tokenize) =
    [ (TokenType.Number, (0I, 0I), (0I, 20I)) ]

  ("1.0" |> tokenize) = [ (TokenType.Number, (0I, 0I), (0I, 3I)) ]

  ("\"hello\"" |> tokenize) =
    [ (TokenType.Symbol, (0I, 0I), (0I, 1I))
      (TokenType.String, (0I, 1I), (0I, 6I))
      (TokenType.Symbol, (0I, 6I), (0I, 7I)) ]

  ("$\"hello {name}\"" |> tokenize) =
    [ (TokenType.Symbol, (0I, 0I), (0I, 1I))
      (TokenType.Symbol, (0I, 1I), (0I, 2I))
      (TokenType.String, (0I, 2I), (0I, 8I))
      (TokenType.Symbol, (0I, 8I), (0I, 9I))
