      (TokenType.Keyword, (0I, 14I), (0I, 18I))
      (TokenType.Symbol, (0I, 18I), (0I, 19I)) ]



  // Record/record-update tokenization regression coverage.
  // A previous .range-related RTE in this area makes this worth keeping explicit.
  ("MyRecord {fieldOne = 1L; fieldTwo = 2L} " |> tokenize) =
