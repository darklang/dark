      (TokenType.Symbol, (0I, 1I), (0I, 2I))
      (TokenType.String, (0I, 2I), (0I, 8I))
      (TokenType.Symbol, (0I, 8I), (0I, 9I))
      (TokenType.VariableName, (0I, 9I), (0I, 13I))
      (TokenType.Symbol, (0I, 13I), (0I, 14I))
      (TokenType.String, (0I, 14I), (0I, 21I))
      (TokenType.Symbol, (0I, 21I), (0I, 22I))
      (TokenType.VariableName, (0I, 22I), (0I, 25I))
      (TokenType.Symbol, (0I, 25I), (0I, 26I))
      (TokenType.Symbol, (0I, 26I), (0I, 27I)) ]


  ("[true; false; true]" |> tokenize) =
    [ (TokenType.Symbol, (0I, 0I), (0I, 1I))
      (TokenType.Keyword, (0I, 1I), (0I, 5I))
      (TokenType.Keyword, (0I, 7I), (0I, 12I))
      (TokenType.Keyword, (0I, 14I), (0I, 18I))
      (TokenType.Symbol, (0I, 18I), (0I, 19I)) ]


  ("Dict { a = 1L; b = 2L }" |> tokenize) =
    [ (TokenType.Keyword, (0I, 0I), (0I, 4I))
      (TokenType.Symbol, (0I, 5I), (0I, 6I))
      (TokenType.Property, (0I, 7I), (0I, 8I))
