      (TokenType.Symbol, (0I, 20I), (0I, 21I))
      (TokenType.Symbol, (0I, 22I), (0I, 23I)) ]


  ("(true, false, true)" |> tokenize) =
    [ (TokenType.Symbol, (0I, 0I), (0I, 1I))
      (TokenType.Keyword, (0I, 1I), (0I, 5I))
      (TokenType.Symbol, (0I, 5I), (0I, 6I))
