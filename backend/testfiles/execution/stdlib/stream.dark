// Stream builtins — chunks 2.5 (consumption) + 2.7 (map/filter/take/concat).
// Chunk 2.6 added the StreamImpl variants the transforms wrap.

// fromList -> toList roundtrips
(let s = Builtin.streamFromList<Int64> [ 1L; 2L; 3L ]
 Builtin.streamToList<Int64> s) = [ 1L; 2L; 3L ]

// empty stream drains to empty list
(let s = Builtin.streamFromList<Int64> []
 Builtin.streamToList<Int64> s) = []

// next on an empty stream returns None
(let s = Builtin.streamFromList<Int64> []
 Builtin.streamNext<Int64> s) = Stdlib.Option.Option.None

// next pulls head, leaves rest
(let s = Builtin.streamFromList<Int64> [ 7L; 8L ]
 let first = Builtin.streamNext<Int64> s
 let second = Builtin.streamNext<Int64> s
 let third = Builtin.streamNext<Int64> s
 [ first; second; third ]) = [ Stdlib.Option.Option.Some 7L
                               Stdlib.Option.Option.Some 8L
                               Stdlib.Option.Option.None ]

// toBlob drains a Stream<UInt8> into a Blob
(let s = Builtin.streamFromList<UInt8> [ 104uy; 105uy ]
 let b = Builtin.streamToBlob s
 Builtin.bytesToString b) = Stdlib.Result.Result.Ok "hi"

// close is idempotent; subsequent next returns None
(let s = Builtin.streamFromList<Int64> [ 1L; 2L ]
 let _ = Builtin.streamClose<Int64> s
 let _ = Builtin.streamClose<Int64> s
 Builtin.streamNext<Int64> s) = Stdlib.Option.Option.None


// --- chunk 2.7 transforms ---

// map doubles every element
(let s = Builtin.streamFromList<Int64> [ 1L; 2L; 3L ]
 let mapped = Builtin.streamMap<Int64, Int64> s (fun n -> n * 2L)
 Builtin.streamToList<Int64> mapped) = [ 2L; 4L; 6L ]

// filter keeps only matching elements
(let s = Builtin.streamFromList<Int64> [ 1L; 2L; 3L; 4L ]
 let evens = Builtin.streamFilter<Int64> s (fun n -> n % 2L == 0L)
 Builtin.streamToList<Int64> evens) = [ 2L; 4L ]

// filter rejecting everything yields empty
(let s = Builtin.streamFromList<Int64> [ 1L; 3L; 5L ]
 let none = Builtin.streamFilter<Int64> s (fun n -> n % 2L == 0L)
 Builtin.streamToList<Int64> none) = []

// take caps at n
(let s = Builtin.streamFromList<Int64> [ 10L; 20L; 30L; 40L ]
 let first2 = Builtin.streamTake<Int64> s 2L
 Builtin.streamToList<Int64> first2) = [ 10L; 20L ]

// take more than available returns all available
(let s = Builtin.streamFromList<Int64> [ 7L; 8L ]
 let wide = Builtin.streamTake<Int64> s 10L
 Builtin.streamToList<Int64> wide) = [ 7L; 8L ]

// take 0 returns empty without pulling
(let s = Builtin.streamFromList<Int64> [ 1L; 2L ]
 let none = Builtin.streamTake<Int64> s 0L
 Builtin.streamToList<Int64> none) = []

// concat drains streams in list order
(let a = Builtin.streamFromList<Int64> [ 1L; 2L ]
 let b = Builtin.streamFromList<Int64> [ 3L; 4L ]
 let joined = Builtin.streamConcat<Int64> [ a; b ]
 Builtin.streamToList<Int64> joined) = [ 1L; 2L; 3L; 4L ]

// concat over an empty list yields empty
(let joined = Builtin.streamConcat<Int64> []
 Builtin.streamToList<Int64> joined) = []

// concat skips an empty sub-stream in the middle
(let a = Builtin.streamFromList<Int64> [ 1L ]
 let empty = Builtin.streamFromList<Int64> []
 let b = Builtin.streamFromList<Int64> [ 2L ]
 let joined = Builtin.streamConcat<Int64> [ a; empty; b ]
 Builtin.streamToList<Int64> joined) = [ 1L; 2L ]

// the spec done-when: filter evens, map +1, take 3, toList
// [1..10] -> evens [2,4,6,8,10] -> +1 [3,5,7,9,11] -> take 3 [3,5,7]
(let s =
   Builtin.streamFromList<Int64>
     [ 1L; 2L; 3L; 4L; 5L; 6L; 7L; 8L; 9L; 10L ]
 let filtered = Builtin.streamFilter<Int64> s (fun n -> n % 2L == 0L)
 let mapped = Builtin.streamMap<Int64, Int64> filtered (fun n -> n + 1L)
 let taken = Builtin.streamTake<Int64> mapped 3L
 Builtin.streamToList<Int64> taken) = [ 3L; 5L; 7L ]
