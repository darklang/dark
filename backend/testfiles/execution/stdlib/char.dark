let smiley () : Char =
  "😂" |> Stdlib.String.head |> Builtin.unwrap

let hand () : Char =
  "✋🏿" |> Stdlib.String.head |> Builtin.unwrap

let family () : Char =
  "👩‍👩‍👧‍👦" |> Stdlib.String.head |> Builtin.unwrap

