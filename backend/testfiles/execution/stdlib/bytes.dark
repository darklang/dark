Stdlib.Bytes.hexEncode_v0 (Stdlib.String.toBytes_v0 "123qwc") = "313233717763"

Stdlib.Bytes.hexEncode_v0 (Stdlib.String.toBytes_v0 "اختبار النص") = "D8A7D8AED8AAD8A8D8A7D8B120D8A7D984D986D8B5"

Stdlib.Bytes.hexEncode_v0 (Stdlib.String.toBytes_v0 "👱👱🏻👱🏼👱🏽👱🏾👱🏿") = "F09F91B1F09F91B1F09F8FBBF09F91B1F09F8FBCF09F91B1F09F8FBDF09F91B1F09F8FBEF09F91B1F09F8FBF"

Stdlib.Bytes.hexEncode_v0 (
  Stdlib.String.toBytes_v0
    "dlkjkd329823333333333fjfidjsfudsdhs}{||!|!|!|!!$%^&^&﷽﷽﷽﷽﷽﷽﷽﷽﷽﷽﷽﷽﷽﷽﷽﷽"
) = "646C6B6A6B64333239383233333333333333333333666A6669646A73667564736468737D7B7C7C217C217C217C212124255E265E26EFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BDEFB7BD"


// --- New Blob-based Bytes API (chunk 1.7) ---

// length
Builtin.bytesLength (Builtin.bytesFromString "hi") = 2L
Builtin.bytesLength (Builtin.bytesFromString "") = 0L

// fromString / toString roundtrip
(match Builtin.bytesToString (Builtin.bytesFromString "hello") with
 | Ok s -> s
 | Error e -> e) = "hello"

// fromHex returns Result<Blob,String>; length of decoded deadbeef = 4 bytes
(match Builtin.bytesFromHex "deadbeef" with
 | Ok b -> Builtin.bytesLength b
 | Error _ -> -1L) = 4L

// toHex roundtrip (uppercase output)
Builtin.bytesToHex (Builtin.bytesFromString "ok") = "6F6B"

// base64 roundtrip
(match Builtin.bytesFromBase64 "aGVsbG8=" with
 | Ok b ->
   (match Builtin.bytesToString b with
    | Ok s -> s
    | Error e -> e)
 | Error e -> e) = "hello"

Builtin.bytesToBase64 (Builtin.bytesFromString "hello") = "aGVsbG8="

// concat
(match Builtin.bytesToString
        (Builtin.bytesConcat
          [ Builtin.bytesFromString "foo"; Builtin.bytesFromString "bar" ]) with
 | Ok s -> s
 | Error _ -> "err") = "foobar"

// slice (middle three bytes of "abcdef" = "cde")
(match Builtin.bytesToString
        (Builtin.bytesSlice (Builtin.bytesFromString "abcdef") 2L 3L) with
 | Ok s -> s
 | Error _ -> "err") = "cde"

// toList escape hatch: first three bytes of "abc" = [97, 98, 99]
Builtin.bytesToList (Builtin.bytesFromString "abc") = [ 97uy; 98uy; 99uy ]

// fromList escape hatch: length 3
Builtin.bytesLength (Builtin.bytesFromList [ 97uy; 98uy; 99uy ]) = 3L


// --- Stdlib.Bytes.* wrapper API (chunk 1.13) ---
// Exercises the Dark-side module surface added in 1.10. Same
// semantics as the Builtin.* cases above, but drives the public
// stdlib module so any wrapper-layer regressions (eg. chunk 1.7 →
// 1.10 name changes) show up here.

Stdlib.Bytes.length (Stdlib.Bytes.fromString "hi") = 2L
Stdlib.Bytes.length (Stdlib.Bytes.fromString "") = 0L

// fromString / toString roundtrip
(match Stdlib.Bytes.toString (Stdlib.Bytes.fromString "hello") with
 | Ok s -> s
 | Error e -> e) = "hello"

// hex roundtrip via wrapper
(match Stdlib.Bytes.fromHex "48656c6c6f" with
 | Ok b ->
   (match Stdlib.Bytes.toString b with
    | Ok s -> s
    | Error e -> e)
 | Error e -> e) = "Hello"

Stdlib.Bytes.toHex (Stdlib.Bytes.fromString "Hi") = "4869"

// base64 roundtrip via wrapper
Stdlib.Bytes.toBase64 (Stdlib.Bytes.fromString "hello") = "aGVsbG8="

(match Stdlib.Bytes.fromBase64 "aGVsbG8=" with
 | Ok b ->
   (match Stdlib.Bytes.toString b with
    | Ok s -> s
    | Error e -> e)
 | Error e -> e) = "hello"

// concat via wrapper
(match Stdlib.Bytes.toString
        (Stdlib.Bytes.concat
          [ Stdlib.Bytes.fromString "foo"
            Stdlib.Bytes.fromString "-"
            Stdlib.Bytes.fromString "bar" ]) with
 | Ok s -> s
 | Error _ -> "err") = "foo-bar"

// slice via wrapper (three middle bytes of "abcdef" = "cde")
(match Stdlib.Bytes.toString
        (Stdlib.Bytes.slice (Stdlib.Bytes.fromString "abcdef") 2L 3L) with
 | Ok s -> s
 | Error _ -> "err") = "cde"

// toList/fromList escape hatches
Stdlib.Bytes.toList (Stdlib.Bytes.fromString "abc") = [ 97uy; 98uy; 99uy ]
Stdlib.Bytes.length (Stdlib.Bytes.fromList [ 97uy; 98uy; 99uy ]) = 3L